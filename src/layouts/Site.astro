---
const {
  title = "Conversiv — The Exit Agency",
  description = "Conversiv helps owner-operators position their business for a max selling price.",
  active = ""
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/conversiv-mark.svg" />
    <link rel="apple-touch-icon" href="/conversiv-mark.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lato:wght@300;400;600;700&family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet" />
    <style is:inline>
      /* ── Reset & Root ──────────────────────────────────────────────── */
      /* Tokens aligned to Conversiv brand audit (C:/Dev/website-audits/conversiv-brand-audit.md, 2026-04-29) */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root {
        --light:    #F5F5F5;       /* near-white hero / light sections */
        --light2:   #FFFFFF;       /* white content sections */
        --light3:   #E8E8E8;       /* hairline borders */
        --ink:      #333333;       /* body text (audit) */
        --ink2:     #555555;       /* secondary text */
        --gray:     #555555;
        --gray2:    #777777;
        --blue:     #4381C3;       /* Conversiv Blue — primary accent */
        --blue-link:#337AB7;       /* hyperlinks */
        --navy:     #285072;       /* Deep Navy — CTA dark variant */
        --black:    #000000;       /* dark sections + nav */
        --muted:    #CCD6DF;       /* light blue muted text on dark */
        --pale:     #C8D5DC;       /* pale blue tint */
        --amber-rare:#AA5500;      /* SPARSE amber — use rarely (audit) */
        --serif:    'Roboto', sans-serif;     /* H1, H2 — Light 300 per audit */
        --sans:     'Lato', -apple-system, sans-serif;  /* body, H3 */
        --font-nav: 'Inter', sans-serif;      /* nav links — UPPERCASE per audit */

        /* Legacy token aliases — kept so page-specific CSS keeps compiling without renames.
           Visual meaning: amber* now points to Conversiv Blue, navy2 to black, cream* to light surfaces. */
        --cream:   #F5F5F5;
        --cream2:  #FFFFFF;
        --cream3:  #E8E8E8;
        --amber:   #4381C3;
        --amber2:  #285072;
        --navy2:   #000000;
      }
      html { scroll-behavior: smooth; }
      body { font-family: var(--sans); background: var(--light2); color: var(--ink); line-height: 1.55; -webkit-font-smoothing: antialiased; font-weight: 400; font-size: 15px; }
      h1 { font-family: var(--serif); font-weight: 300; line-height: 1.1; color: var(--blue); }
      h2 { font-family: var(--serif); font-weight: 300; line-height: 1.15; color: var(--ink); }
      h3 { font-family: var(--sans); font-weight: 600; line-height: 1.25; color: var(--blue); }
      a { color: inherit; text-decoration: none; }
      .container { max-width: 1180px; margin: 0 auto; padding: 0 2rem; }

      /* ── TOP BAR ─────────────────────────────────────────────────────── */
      .top-bar { background: var(--black); color: #fff; text-align: center; padding: 0.55rem 1rem; font-family: var(--font-nav); font-size: 0.78rem; font-weight: 500; letter-spacing: 0.02em; border-bottom: 1px solid #1a1a1a; }
      .top-bar a { color: var(--blue); font-weight: 600; text-decoration: underline; text-underline-offset: 2px; }

      /* ── NAV (audit: solid black, white uppercase Inter, letter-spacing -0.2px) ── */
      nav { position: sticky; top: 0; z-index: 100; background: var(--black); padding: 1.1rem 0; }
      .nav-inner { display: flex; align-items: center; justify-content: space-between; gap: 2rem; }
      .nav-logo { display: inline-flex; align-items: baseline; font-family: var(--sans); font-size: 1.4rem; font-weight: 400; color: #fff; letter-spacing: -0.01em; text-transform: lowercase; }
      .nav-links { display: flex; gap: 2rem; list-style: none; font-family: var(--font-nav); font-size: 0.875rem; font-weight: 500; letter-spacing: -0.2px; text-transform: uppercase; color: #fff; }
      .nav-links a { color: #fff; transition: color 0.2s; }
      .nav-links a:hover, .nav-links a.active { color: var(--blue); }
      .nav-cta { display: inline-flex; align-items: center; font-family: var(--serif); font-size: 0.875rem; font-weight: 500; letter-spacing: 0.02em; text-transform: uppercase; color: var(--blue); background: transparent; padding: 0.65rem 1.4rem; border: 1.6px solid var(--blue); border-radius: 0; transition: background 0.2s, color 0.2s; white-space: nowrap; }
      .nav-cta:hover { background: var(--blue); color: #fff; }

      /* ── BUTTONS (audit pattern: GHOST/outlined — transparent bg, blue border + blue text, UPPERCASE) ── */
      .btn-ink, .btn-blue, .btn-ghost { display: inline-flex; align-items: center; gap: 0.5rem; background: transparent; color: var(--blue); border: 1.6px solid var(--blue); padding: 0.85rem 1.75rem; border-radius: 0; font-family: var(--serif); font-size: 0.9375rem; font-weight: 500; letter-spacing: 0.02em; text-transform: uppercase; transition: background 0.2s, color 0.2s; }
      .btn-ink:hover, .btn-blue:hover, .btn-ghost:hover { background: var(--blue); color: #fff; }
      .btn-outline { display: inline-flex; align-items: center; gap: 0.5rem; background: transparent; color: var(--ink); border: 1.6px solid var(--ink); padding: 0.85rem 1.75rem; border-radius: 0; font-family: var(--serif); font-size: 0.9375rem; font-weight: 500; letter-spacing: 0.02em; text-transform: uppercase; transition: background 0.2s, color 0.2s, border-color 0.2s; }
      .btn-outline:hover { border-color: var(--blue); color: var(--blue); }
      .btn-amber, .btn-filled { display: inline-flex; align-items: center; gap: 0.5rem; background: var(--blue); color: #fff; border: 1.6px solid var(--blue); padding: 0.85rem 1.75rem; border-radius: 0; font-family: var(--serif); font-size: 0.9375rem; font-weight: 500; letter-spacing: 0.02em; text-transform: uppercase; transition: background 0.2s, border-color 0.2s; }
      .btn-amber:hover, .btn-filled:hover { background: var(--navy); border-color: var(--navy); }
      .btn-ghost-light { display: inline-flex; align-items: center; gap: 0.5rem; background: transparent; color: #fff; border: 1.6px solid #fff; padding: 0.85rem 1.75rem; border-radius: 0; font-family: var(--serif); font-size: 0.9375rem; font-weight: 500; letter-spacing: 0.02em; text-transform: uppercase; transition: background 0.2s, color 0.2s; }
      .btn-ghost-light:hover { background: #fff; color: var(--black); }

      /* ── SHARED SECTION DRESS ───────────────────────────────────────── */
      .section-eyebrow { font-family: var(--font-nav); font-size: 0.78rem; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; color: var(--blue); margin-bottom: 0.85rem; display: block; }
      .section-heading { font-family: var(--serif); font-weight: 300; font-size: clamp(1.8rem, 3vw, 2.4rem); color: inherit; margin-bottom: 3rem; max-width: 760px; line-height: 1.18; }
      .section-heading em { font-style: normal; color: var(--blue); }
      .on-dark .section-heading, .on-dark h2 { color: #fff; }
      .on-dark .section-heading em, .on-dark h2 em { color: var(--blue); }
      .on-dark .section-eyebrow { color: var(--blue); }
      .on-dark p { color: var(--muted); }

      /* ── PAGE HERO (inner pages) ───────────────────────────────────── */
      .page-hero { background: var(--light); padding: 5.5rem 0 4.5rem; border-bottom: 1px solid var(--light3); }
      .page-hero-inner { max-width: 960px; }
      .page-hero-eyebrow { font-family: var(--font-nav); font-size: 0.78rem; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; color: var(--blue); margin-bottom: 1.25rem; display: inline-flex; align-items: center; gap: 0.6rem; }
      .page-hero-eyebrow::before { content: ''; width: 28px; height: 1px; background: var(--blue); }
      .page-hero h1 { font-family: var(--serif); font-weight: 300; font-size: clamp(2.2rem, 4.4vw, 3.4rem); line-height: 1.1; letter-spacing: -0.005em; color: var(--blue); margin-bottom: 1.25rem; }
      .page-hero h1 em { font-style: normal; color: var(--navy); }
      .page-hero-sub { font-family: var(--sans); font-size: 1.05rem; color: var(--ink); max-width: 700px; line-height: 1.65; font-weight: 400; margin-bottom: 2.5rem; }
      .page-hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

      /* ── CTA (dark) ───────────────────────────────────────────────────── */
      .cta-dark { background: var(--black); padding: 7rem 0; text-align: center; }
      .cta-dark h2 { font-family: var(--serif); font-weight: 300; font-size: clamp(2rem, 4vw, 3rem); color: #fff; max-width: 720px; margin: 0 auto 1.25rem; line-height: 1.15; }
      .cta-dark h2 em { font-style: normal; color: var(--blue); }
      .cta-dark p { font-size: 1rem; color: var(--muted); max-width: 520px; margin: 0 auto 2.5rem; font-weight: 400; line-height: 1.7; }
      .cta-dark-actions { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; }
      .cta-note { margin-top: 1.75rem; font-size: 0.75rem; color: rgba(255,255,255,0.5); letter-spacing: 0.05em; }

      /* ── FOOTER ──────────────────────────────────────────────────────── */
      footer { background: var(--black); padding: 4rem 0 3rem; color: rgba(255,255,255,0.7); }
      .footer-inner { display: grid; grid-template-columns: 1.6fr 1fr 1fr 1.2fr; gap: 3rem; margin-bottom: 3rem; }
      .footer-brand-logo { font-family: var(--sans); font-size: 1.4rem; font-weight: 400; color: #fff; letter-spacing: -0.01em; text-transform: lowercase; }
      .footer-brand-tag { font-family: var(--font-nav); font-size: 0.7rem; color: var(--blue); letter-spacing: 0.16em; text-transform: uppercase; margin-top: 0.5rem; font-weight: 600; }
      .footer-brand-desc { font-size: 0.85rem; color: rgba(255,255,255,0.6); line-height: 1.7; font-weight: 400; margin-top: 0.85rem; max-width: 260px; }
      .footer-col-head { font-family: var(--font-nav); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; color: var(--blue); margin-bottom: 1.1rem; }
      .footer-links-list { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; }
      .footer-links-list a { font-size: 0.85rem; color: rgba(255,255,255,0.7); transition: color 0.2s; }
      .footer-links-list a:hover { color: var(--blue); }
      .footer-bar { display: flex; align-items: center; justify-content: space-between; border-top: 1px solid rgba(255,255,255,0.12); padding-top: 1.5rem; flex-wrap: wrap; gap: 1rem; }
      .footer-copy { font-size: 0.72rem; color: rgba(255,255,255,0.45); }

      /* ── Fade-in ─────────────────────────────────────────────────────── */
      .fade-in { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
      .fade-in.visible { opacity: 1; transform: none; }

      /* ── Responsive ──────────────────────────────────────────────────── */
      @media (max-width: 960px) {
        .nav-links, .nav-cta { display: none; }
        .footer-inner { grid-template-columns: 1fr 1fr; }
      }
    </style>
    <slot name="head" />
  </head>
  <body>

    <!-- TOP BAR -->
    <div class="top-bar">
      Get your free exit audit in 15 minutes. <a href="/start">Start now</a>
    </div>

    <!-- NAV -->
    <nav>
      <div class="container">
        <div class="nav-inner">
          <a href="/" class="nav-logo">conversiv</a>
          <ul class="nav-links">
            <li><a href="/" class={active === 'home' ? 'active' : ''}>Exit Agency</a></li>
            <li><a href="/services/messaging" class={active === 'messaging' ? 'active' : ''}>Messaging</a></li>
            <li><a href="/agencies" class={active === 'agencies' ? 'active' : ''}>For Agencies</a></li>
            <li><a href="/agentexit" class={active === 'agentexit' ? 'active' : ''}>AgentExit</a></li>
          </ul>
          <a href="/start" class="nav-cta">Free exit audit</a>
        </div>
      </div>
    </nav>

    <slot />

    <!-- FOOTER -->
    <footer>
      <div class="container">
        <div class="footer-inner">
          <div>
            <div class="footer-brand-logo">conversiv</div>
            <div class="footer-brand-tag">The Exit Agency</div>
            <p class="footer-brand-desc">We help owner-operators position their business for a max selling price. So you get more for it. Sooner.</p>
          </div>
          <div>
            <div class="footer-col-head">Services</div>
            <ul class="footer-links-list">
              <li><a href="/">Exit Agency</a></li>
              <li><a href="/services/messaging">Messaging &amp; Brand</a></li>
              <li><a href="/agencies">For Agencies</a></li>
            </ul>
          </div>
          <div>
            <div class="footer-col-head">Platform</div>
            <ul class="footer-links-list">
              <li><a href="/agentexit">AgentExit</a></li>
            </ul>
          </div>
          <div>
            <div class="footer-col-head">Connect</div>
            <ul class="footer-links-list">
              <li><a href="/start">Free exit audit</a></li>
              <li><a href="/demo">Book your demo</a></li>
              <li><a href="mailto:hello@conversiv.com">hello@conversiv.com</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bar">
          <div class="footer-copy">&copy; 2026 Conversiv. All rights reserved.</div>
          <div class="footer-copy">Exit strategy &middot; Message optimization &middot; AgentExit</div>
        </div>
      </div>
    </footer>

    <script is:inline>
      const fadeObs = new IntersectionObserver((entries) => {
        entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); fadeObs.unobserve(e.target); } });
      }, { threshold: 0.12 });
      document.querySelectorAll('.fade-in').forEach(el => fadeObs.observe(el));
    </script>

  </body>
</html>
