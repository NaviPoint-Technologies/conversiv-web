---
// AgentExit — the canonical Conversiv platform page (2026-05-12 Adam decision).
// OptiqOS is the internal/wholesale platform name; AgentExit is the productized name visitors see.
// /optiqos no longer exists publicly — staticwebapp.config.json redirects it here.
import Site from '../layouts/Site.astro';
const product = "AgentExit";
const productTag = "The Conversiv platform";
const productDesc = "AgentExit connects every channel you run, every campaign you launch, and every operational metric that backs them — into one view.";
---
<Site
  title={`${product} — The Conversiv platform`}
  description={`${product} connects every channel, every campaign, and every operational metric into one view. So your message gets sharper, your operations get tighter, and you can see the work happening — together.`}
  active="agentexit"
>
  <style is:inline slot="head">
    .pl-feature { background: var(--light2); padding: 7rem 0; border-bottom: 1px solid var(--light3); }
    .pl-feature-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: start; }
    .pl-chip { display: inline-flex; align-items: center; gap: 0.5rem; background: transparent; border: 1px solid var(--blue); color: var(--blue); font-family: var(--font-nav); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; padding: 0.35rem 0.9rem; border-radius: 0; margin-bottom: 1.5rem; }
    .pl-feature h2 { font-family: var(--serif); font-weight: 300; font-size: clamp(1.9rem, 3vw, 2.8rem); color: var(--ink); margin-bottom: 1rem; line-height: 1.15; }
    .pl-feature h2 em { font-style: normal; color: var(--blue); }
    .pl-sub { font-family: var(--font-nav); font-size: 0.85rem; color: var(--blue); font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 1.25rem; }
    .pl-feature p { font-size: 0.95rem; color: var(--ink); line-height: 1.8; font-weight: 400; margin-bottom: 1.1rem; }
    .feature-list { list-style: none; margin-top: 2rem; display: flex; flex-direction: column; border-top: 1.5px solid var(--light3); padding-top: 1.25rem; }
    .feature-list li { display: flex; align-items: flex-start; gap: 1rem; padding: 1rem 0; border-bottom: 1px solid var(--light3); font-size: 0.9rem; }
    .feature-list li:last-child { border-bottom: none; }
    .feat-num { font-family: var(--serif); font-weight: 300; font-size: 1.3rem; color: var(--blue); width: 1.6rem; flex-shrink: 0; margin-top: 0.05rem; }
    .feat-text strong { display: block; font-size: 0.9rem; font-weight: 600; color: var(--ink); margin-bottom: 0.25rem; }
    .feat-text span { font-size: 0.85rem; color: var(--gray); font-weight: 400; line-height: 1.55; }
    .pl-visual { position: sticky; top: 6rem; }
    .stat-display { background: var(--light); border: 1px solid var(--light3); padding: 2.25rem; }
    .stat-display-head { font-family: var(--font-nav); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gray); margin-bottom: 1.5rem; }
    .stat-display-items { display: flex; flex-direction: column; gap: 0.85rem; }
    .sdi { display: flex; align-items: center; justify-content: space-between; padding: 0.95rem 1.2rem; background: #fff; border: 1px solid var(--light3); }
    .sdi-label { font-size: 0.8rem; font-weight: 500; color: var(--ink); }
    .sdi-value { font-family: var(--serif); font-weight: 400; font-size: 1.35rem; color: var(--blue); }
    .sdi-delta { font-family: var(--font-nav); font-size: 0.65rem; font-weight: 600; color: #1B7332; background: rgba(34,197,94,0.1); padding: 0.18rem 0.55rem; border-radius: 100px; letter-spacing: 0.04em; }
    .sdi-delta.warn { color: var(--amber-rare); background: rgba(170,85,0,0.1); }
    .sdi-right { display: flex; align-items: center; gap: 0.5rem; }
    .insight-light { margin-top: 1.25rem; background: rgba(67,129,195,0.08); border-left: 3px solid var(--blue); padding: 0.95rem 1.15rem; font-size: 0.85rem; color: var(--ink); line-height: 1.6; }
    .insight-light strong { color: var(--blue); }

    .pl-problem { background: var(--light); padding: 7rem 0; border-bottom: 1px solid var(--light3); }
    .pl-problem-inner { max-width: 760px; margin: 0 auto; text-align: center; }
    .pl-problem h2 { font-family: var(--serif); font-weight: 300; font-size: clamp(1.9rem, 3vw, 2.6rem); color: var(--ink); margin-bottom: 1.25rem; line-height: 1.18; }
    .pl-problem h2 em { font-style: normal; color: var(--blue); }
    .pl-problem p { font-size: 1.05rem; color: var(--ink); line-height: 1.75; font-weight: 400; margin-bottom: 1rem; }

    .pl-connect { background: var(--light2); padding: 7rem 0; border-bottom: 1px solid var(--light3); }
    .pl-connectors { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-top: 3rem; }
    .pl-connector { background: var(--light); border: 1px solid var(--light3); padding: 1.5rem 1.25rem; text-align: center; font-size: 0.85rem; font-weight: 600; color: var(--ink); letter-spacing: 0.02em; }
    .pl-connector-cat { display: block; font-family: var(--font-nav); font-size: 0.62rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: var(--blue); margin-bottom: 0.5rem; }

    .pl-insights { background: var(--light); padding: 7rem 0; border-bottom: 1px solid var(--light3); }
    .pl-insights-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 3rem; }
    .pl-insight { background: #fff; border: 1px solid var(--light3); border-left: 3px solid var(--blue); padding: 2rem; }
    .pl-insight-label { font-family: var(--font-nav); font-size: 0.65rem; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; color: var(--blue); margin-bottom: 0.85rem; }
    .pl-insight p { font-family: var(--serif); font-weight: 300; font-size: 1.05rem; line-height: 1.5; color: var(--ink); }
    .pl-insight strong { color: var(--blue); font-weight: 400; }

    .pl-callout { background: var(--black); padding: 7rem 0; color: rgba(255,255,255,0.85); }
    .pl-callout-inner { display: grid; grid-template-columns: 1fr 1.3fr; gap: 4rem; align-items: center; }
    .pl-callout-eyebrow { color: var(--blue); font-family: var(--font-nav); font-size: 0.75rem; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; margin-bottom: 1.25rem; }
    .pl-callout h2 { font-family: var(--serif); font-size: clamp(1.7rem, 2.6vw, 2.2rem); color: #fff; line-height: 1.2; font-weight: 300; }
    .pl-callout h2 em { font-style: normal; color: var(--blue); }
    .pl-callout p { font-size: 0.98rem; line-height: 1.75; color: rgba(255,255,255,0.7); font-weight: 400; }
    .pl-callout-cta { margin-top: 1.5rem; display: inline-flex; align-items: center; gap: 0.5rem; color: var(--blue); font-family: var(--serif); font-size: 0.875rem; font-weight: 500; letter-spacing: 0.04em; text-transform: uppercase; border: 1.6px solid var(--blue); padding: 0.65rem 1.25rem; transition: background 0.2s, color 0.2s; }
    .pl-callout-cta:hover { background: var(--blue); color: #fff; }

    .pl-pricing-note { background: var(--light2); padding: 4rem 0; border-bottom: 1px solid var(--light3); text-align: center; }
    .pl-pricing-note span { font-size: 0.78rem; font-weight: 600; letter-spacing: 0.04em; color: var(--gray); }
    .pl-pricing-note a { color: var(--blue); font-weight: 700; }

    @media (max-width: 960px) {
      .pl-feature-inner, .pl-callout-inner { grid-template-columns: 1fr; gap: 3rem; }
      .pl-visual { position: static; }
      .pl-connectors { grid-template-columns: repeat(2, 1fr); }
      .pl-insights-grid { grid-template-columns: 1fr; }
    }
  </style>

  <!-- HERO -->
  <section class="page-hero">
    <div class="container">
      <div class="page-hero-inner fade-in">
        <div class="page-hero-eyebrow">The platform</div>
        <h1>One view of every channel. <em>One source of truth</em> for your message.</h1>
        <p class="page-hero-sub">
          {productDesc} So your message gets sharper, your operations get tighter, and you can see the work happening &mdash; together, in the same place.
        </p>
        <div class="page-hero-actions">
          <a href="/demo" class="btn-ink">Book a demo &rarr;</a>
          <a href="#what" class="btn-outline">What&rsquo;s inside</a>
        </div>
      </div>
    </div>
  </section>

  <!-- PROBLEM -->
  <section class="pl-problem">
    <div class="container">
      <div class="pl-problem-inner fade-in">
        <span class="section-eyebrow">The problem</span>
        <h2>Tools don&rsquo;t talk. Agencies hand you <em>reports</em>, not a system.</h2>
        <p>Every channel lives in its own dashboard. Every agency hands back a different slide deck. Your finance team has the truth. Your marketing team has the story. Nobody has both in the same view.</p>
        <p>So you make decisions on lagging instinct &mdash; and the gap between your message and your operations quietly compounds.</p>
      </div>
    </div>
  </section>

  <!-- FEATURE / DASHBOARD -->
  <section class="pl-feature" id="what">
    <div class="container">
      <div class="pl-feature-inner">
        <div class="fade-in">
          <div class="pl-chip">{productTag}</div>
          <h2>Connect your <em>message</em><br />to your operations.</h2>
          <p class="pl-sub">{product}. Built for owner-operators and the agencies that serve them.</p>
          <p>Most agencies hand you a brand book and a quarterly report. {product} connects every channel you run, every campaign you launch, and every operational metric that backs them &mdash; into one view.</p>
          <p>So your message gets sharper, your operations get tighter, and you can see the work happening &mdash; together, in the same place.</p>
          <ul class="feature-list">
            <li>
              <div class="feat-num">1</div>
              <div class="feat-text"><strong>One view of every channel</strong><span>Google. Meta. Email. Your CRM. Your website. All in one place.</span></div>
            </li>
            <li>
              <div class="feat-num">2</div>
              <div class="feat-text"><strong>Message-to-revenue map</strong><span>See which campaigns, channels, and messages are actually driving qualified business.</span></div>
            </li>
            <li>
              <div class="feat-num">3</div>
              <div class="feat-text"><strong>Plain-English next steps</strong><span>Where to spend the next dollar. Where to stop. Why.</span></div>
            </li>
            <li>
              <div class="feat-num">4</div>
              <div class="feat-text"><strong>Brand and operations, in sync</strong><span>When the message shifts, the dashboard knows. When the data shifts, the strategy adjusts.</span></div>
            </li>
          </ul>
        </div>
        <div class="pl-visual fade-in">
          <div class="stat-display">
            <div class="stat-display-head">{product} &middot; live view</div>
            <div class="stat-display-items">
              <div class="sdi">
                <span class="sdi-label">Brand Score</span>
                <div class="sdi-right"><span class="sdi-value">91%</span><span class="sdi-delta">Optimized</span></div>
              </div>
              <div class="sdi">
                <span class="sdi-label">Qualified Leads (MTD)</span>
                <div class="sdi-right"><span class="sdi-value">142</span><span class="sdi-delta">+18%</span></div>
              </div>
              <div class="sdi">
                <span class="sdi-label">Cost Per Lead</span>
                <div class="sdi-right"><span class="sdi-value">$38</span><span class="sdi-delta warn">Review</span></div>
              </div>
              <div class="sdi">
                <span class="sdi-label">Channel Mix Drift</span>
                <div class="sdi-right"><span class="sdi-value">-22%</span><span class="sdi-delta warn">Meta Q/Q</span></div>
              </div>
              <div class="sdi">
                <span class="sdi-label">Revenue Trend (MoM)</span>
                <div class="sdi-right"><span class="sdi-value">+12%</span><span class="sdi-delta">On track</span></div>
              </div>
            </div>
            <div class="insight-light">
              <strong>Top insight:</strong> Your Google review cadence is half what comparable operators run. Closing the gap could lift qualified leads ~24% over the next quarter.
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CONNECTORS -->
  <section class="pl-connect">
    <div class="container">
      <span class="section-eyebrow">The connection layer</span>
      <h2 class="section-heading fade-in">Already wired into the tools you run.</h2>
      <div class="pl-connectors">
        <div class="pl-connector fade-in"><span class="pl-connector-cat">Marketing</span>Google Ads</div>
        <div class="pl-connector fade-in"><span class="pl-connector-cat">Marketing</span>Meta Ads</div>
        <div class="pl-connector fade-in"><span class="pl-connector-cat">Marketing</span>LinkedIn Ads</div>
        <div class="pl-connector fade-in"><span class="pl-connector-cat">Analytics</span>Google Analytics</div>
        <div class="pl-connector fade-in"><span class="pl-connector-cat">Analytics</span>Search Console</div>
        <div class="pl-connector fade-in"><span class="pl-connector-cat">Presence</span>Google Business</div>
        <div class="pl-connector fade-in"><span class="pl-connector-cat">CRM</span>HubSpot</div>
        <div class="pl-connector fade-in"><span class="pl-connector-cat">CRM</span>GoHighLevel</div>
        <div class="pl-connector fade-in"><span class="pl-connector-cat">Finance</span>QuickBooks</div>
        <div class="pl-connector fade-in"><span class="pl-connector-cat">Comms</span>Gmail</div>
        <div class="pl-connector fade-in"><span class="pl-connector-cat">Comms</span>Twilio SMS</div>
        <div class="pl-connector fade-in"><span class="pl-connector-cat">Web</span>Your website</div>
      </div>
    </div>
  </section>

  <!-- INSIGHTS -->
  <section class="pl-insights">
    <div class="container">
      <span class="section-eyebrow">Plain-English insights</span>
      <h2 class="section-heading fade-in">The kind of thing a senior agency lead would notice. Surfaced for you.</h2>
      <div class="pl-insights-grid">
        <div class="pl-insight fade-in">
          <div class="pl-insight-label">Channel drift</div>
          <p>Your <strong>Meta share of spend dropped 22% Q/Q</strong> while Google held flat &mdash; but Meta is where your qualified-lead share comes from. Likely a budget pacing issue, not a strategy decision.</p>
        </div>
        <div class="pl-insight fade-in">
          <div class="pl-insight-label">Message gap</div>
          <p>Your <strong>website headline</strong> and your <strong>top-converting ad</strong> use different language for the same audience. Aligning them historically lifts lead-to-call rate by 15&ndash;20%.</p>
        </div>
        <div class="pl-insight fade-in">
          <div class="pl-insight-label">Operational signal</div>
          <p>Your <strong>Google review cadence</strong> is half what comparable operators run. Closing the gap could lift qualified leads ~24% over the next quarter at no incremental ad spend.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- EXIT CALLOUT -->
  <section class="pl-callout">
    <div class="container">
      <div class="pl-callout-inner">
        <div class="fade-in">
          <div class="pl-callout-eyebrow">For exit-ready businesses</div>
          <h2>When you go to market, your <em>numbers already tell the story.</em></h2>
        </div>
        <div class="fade-in">
          <p>{product} is the system of record behind every Conversiv Exit Agency engagement. When buyers ask hard questions about your channels, your acquisition costs, your retention, and the quality of your pipeline &mdash; the answers are already there. In one place. With the receipts.</p>
          <a href="/" class="pl-callout-cta">See the Exit Agency story &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING NOTE -->
  <section class="pl-pricing-note">
    <div class="container">
      <span>Pricing is engagement-based and includes a Conversiv specialist on every deployment. <a href="/demo">Book a demo</a> for current pricing.</span>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-dark" id="contact">
    <div class="container">
      <h2>See {product} on <em>your data.</em></h2>
      <p>Book a demo. We&rsquo;ll connect a sandbox to two or three of your live sources and walk you through what {product} would see on day one.</p>
      <div class="cta-dark-actions">
        <a href="/demo" class="btn-ghost-light">Book a demo &rarr;</a>
        <a href="/" class="btn-ghost-light">See the Exit Agency story</a>
      </div>
      <p class="cta-note">Connected on day one &middot; Specialist included &middot; No credit card to start</p>
    </div>
  </section>
</Site>
