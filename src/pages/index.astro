---
import Site from '../layouts/Site.astro';
---
<Site
  title="Conversiv — The Exit Agency"
  description="Get more for your business sooner. Conversiv helps owner-operators position their business for a max selling price — by connecting their message to their audiences and their operations."
  active="home"
>
  <style is:inline slot="head">
    /* ── HERO (audit: light gray near-white #F5F5F5, Roboto H1, ghost CTAs) ── */
    .hero { background: var(--light); padding: 6rem 0 5rem; text-align: center; border-bottom: 1px solid var(--light3); }
    .hero-chip { display: inline-flex; align-items: center; gap: 0.6rem; background: transparent; border: 1px solid var(--blue); color: var(--blue); font-family: var(--font-nav); font-size: 0.72rem; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; padding: 0.4rem 1rem; border-radius: 100px; margin-bottom: 2.5rem; }
    .hero-chip::before { content: ''; width: 6px; height: 6px; background: var(--blue); border-radius: 50%; }
    h1.hero-headline { font-family: var(--serif); font-size: clamp(2.6rem, 6vw, 5.4rem); font-weight: 300; line-height: 1.05; letter-spacing: -0.01em; color: var(--blue); max-width: 980px; margin: 0 auto 2rem; }
    .hero-emph { color: var(--navy); font-style: normal; font-weight: 400; }
    .hero-sub { font-family: var(--sans); font-size: 1.05rem; font-weight: 400; color: var(--ink); max-width: 640px; margin: 0 auto 2.5rem; line-height: 1.7; }
    .hero-actions { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; margin-bottom: 1rem; }
    .magic-link-hint { display: block; font-size: 0.72rem; color: var(--gray2); letter-spacing: 0.02em; margin-top: 0.25rem; margin-bottom: 2.5rem; font-weight: 400; }
    .magic-link-hint strong { color: var(--ink); font-weight: 600; }
    .hero-proof { display: flex; align-items: center; justify-content: center; gap: 0.75rem; flex-wrap: wrap; }
    .hero-proof-label { font-family: var(--font-nav); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gray2); }
    .hero-proof-names { display: flex; gap: 0; }
    .proof-name { font-family: var(--font-nav); font-size: 0.72rem; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; color: var(--gray); padding: 0 1rem; border-right: 1px solid var(--light3); }
    .proof-name:last-child { border-right: none; }

    /* ── PROOF MARQUEE (already dark — pattern preserved) ── */
    .proof-marquee { background: var(--black); overflow: hidden; padding: 1.15rem 0; }
    .proof-track { display: flex; align-items: center; width: max-content; animation: marquee-proof 28s linear infinite; }
    .proof-item { font-family: var(--font-nav); padding: 0 2rem; font-size: 0.72rem; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(255,255,255,0.55); white-space: nowrap; }
    .proof-dot { color: var(--blue); padding: 0 0.5rem; }
    @keyframes marquee-proof { from { transform: translateX(0); } to { transform: translateX(-50%); } }

    /* ── PILLAR (white) — Joe's "Get more for your business sooner" ── */
    .pillar { background: var(--light2); padding: 7rem 0; border-bottom: 1px solid var(--light3); text-align: center; }
    .pillar-inner { max-width: 760px; margin: 0 auto; }
    .pillar-eyebrow { font-family: var(--font-nav); font-size: 0.78rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: var(--blue); margin-bottom: 1.25rem; display: block; }
    .pillar h2 { font-family: var(--serif); font-weight: 300; font-size: clamp(2rem, 3.6vw, 3.2rem); margin-bottom: 1.5rem; color: var(--ink); line-height: 1.15; }
    .pillar h2 em { font-style: normal; color: var(--blue); }
    .pillar p { font-size: 1.05rem; color: var(--ink); line-height: 1.7; font-weight: 400; }
    .pillar-cta { margin-top: 2.5rem; }

    /* ── AUTHORITY QUOTE (light gray) ── */
    .authority-quote { background: var(--light); padding: 5rem 0; border-bottom: 1px solid var(--light3); }
    .aq-inner { max-width: 760px; margin: 0 auto; text-align: center; }
    .aq-eyebrow { font-family: var(--font-nav); font-size: 0.75rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: var(--blue); margin-bottom: 1.5rem; display: inline-flex; align-items: center; gap: 0.6rem; }
    .aq-eyebrow::before, .aq-eyebrow::after { content: ''; width: 24px; height: 1px; background: var(--blue); }
    .aq-text { font-family: var(--serif); font-weight: 300; font-size: clamp(1.4rem, 2.6vw, 2rem); line-height: 1.35; color: var(--ink); font-style: italic; margin-bottom: 1.75rem; }
    .aq-attr { display: inline-flex; flex-direction: column; align-items: center; gap: 0.25rem; padding-top: 1.5rem; border-top: 1px solid var(--light3); }
    .aq-name { font-size: 0.82rem; font-weight: 600; color: var(--ink); letter-spacing: 0.03em; }
    .aq-role { font-size: 0.72rem; color: var(--gray); font-weight: 400; }

    /* ── EDITORIAL IMAGE BREAK (black, image) ── */
    .editorial-break { position: relative; overflow: hidden; background: var(--black); border-bottom: 1px solid var(--black); }
    .editorial-break img { width: 100%; height: 56vh; min-height: 440px; max-height: 700px; object-fit: cover; display: block; filter: grayscale(0.65) brightness(0.5) contrast(1.05); }
    .editorial-overlay { position: absolute; inset: 0; display: flex; flex-direction: column; justify-content: flex-end; pointer-events: none; }
    .editorial-overlay-inner { max-width: 1180px; margin: 0 auto; padding: 0 2rem 4rem; width: 100%; pointer-events: auto; }
    .editorial-eyebrow { color: var(--blue); font-family: var(--font-nav); font-size: 0.75rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; margin-bottom: 1.25rem; display: inline-flex; align-items: center; gap: 0.6rem; }
    .editorial-eyebrow::before { content: ''; width: 28px; height: 1px; background: var(--blue); }
    .editorial-quote { font-family: var(--serif); font-weight: 300; font-size: clamp(1.5rem, 3vw, 2.6rem); line-height: 1.18; color: #fff; max-width: 780px; letter-spacing: -0.005em; }
    .editorial-quote em { font-style: normal; color: var(--blue); font-weight: 400; }
    .editorial-attr { font-family: var(--font-nav); font-size: 0.72rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255,255,255,0.55); margin-top: 1.75rem; }

    /* ── WHY CONNECT WITH CONVERSIV (light gray) ── */
    .why-now { background: var(--light); padding: 7rem 0; border-bottom: 1px solid var(--light3); }
    .wn-header { text-align: center; margin-bottom: 4rem; }
    .wn-eyebrow { font-family: var(--font-nav); font-size: 0.78rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: var(--blue); margin-bottom: 1rem; display: block; }
    .wn-heading { font-family: var(--serif); font-weight: 300; font-size: clamp(2rem, 3.6vw, 3rem); color: var(--ink); line-height: 1.15; }
    .wn-heading em { font-style: normal; color: var(--blue); }
    .wn-stats { display: grid; grid-template-columns: repeat(2, 1fr); gap: 4rem; max-width: 880px; margin: 0 auto; }
    .wn-stat { text-align: center; padding: 0 1rem; position: relative; }
    .wn-stat:not(:last-child)::after { content: ''; position: absolute; right: -1.5rem; top: 1rem; bottom: 1rem; width: 1px; background: var(--light3); }
    .wn-stat-num { font-family: var(--serif); font-weight: 300; font-size: clamp(3rem, 5.5vw, 5rem); color: var(--blue); line-height: 1; margin-bottom: 1rem; }
    .wn-stat-label { font-size: 1rem; color: var(--ink); line-height: 1.55; max-width: 280px; margin: 0 auto; font-weight: 400; }

    /* ── PROGRAMS (BLACK section per audit "feature sections solid black") ── */
    .programs { background: var(--black); padding: 7rem 0; }
    .programs .section-eyebrow { color: var(--blue); font-family: var(--font-nav); font-size: 0.78rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; margin-bottom: 0.85rem; display: block; }
    .programs .section-heading { font-family: var(--serif); font-weight: 300; font-size: clamp(2rem, 3.6vw, 3rem); color: #fff; margin-bottom: 3.5rem; max-width: 640px; line-height: 1.15; }
    .programs .section-heading em { font-style: normal; color: var(--blue); }
    .programs-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
    .prog-card { background: transparent; padding: 2.5rem; border: 1px solid rgba(255,255,255,0.15); transition: border-color 0.25s, background 0.25s; display: flex; flex-direction: column; }
    .prog-card:hover { border-color: var(--blue); background: rgba(67,129,195,0.05); }
    .prog-num { font-family: var(--serif); font-weight: 300; font-size: 2.6rem; color: var(--blue); line-height: 1; margin-bottom: 1rem; opacity: 0.7; }
    .prog-card h3 { font-family: var(--sans); font-weight: 600; font-size: 1.8rem; color: #fff; margin-bottom: 0.4rem; }
    .prog-sub { font-family: var(--font-nav); font-size: 0.78rem; color: var(--blue); font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 1.5rem; }
    .prog-card p { font-size: 0.95rem; color: rgba(255,255,255,0.7); line-height: 1.8; font-weight: 400; margin-bottom: 1.75rem; }
    .prog-features { list-style: none; display: flex; flex-direction: column; padding-top: 0.5rem; border-top: 1px solid rgba(255,255,255,0.12); }
    .prog-features li { display: flex; align-items: flex-start; gap: 0.65rem; padding: 0.7rem 0; font-size: 0.9rem; color: rgba(255,255,255,0.85); border-bottom: 1px solid rgba(255,255,255,0.08); }
    .prog-features li::before { content: '\2192'; color: var(--blue); flex-shrink: 0; margin-top: 0.15rem; font-weight: 600; }
    .prog-cta { display: inline-flex; align-items: center; gap: 0.4rem; margin-top: 2rem; font-family: var(--serif); font-size: 0.875rem; font-weight: 500; letter-spacing: 0.04em; text-transform: uppercase; color: var(--blue); border: 1.6px solid var(--blue); padding: 0.65rem 1.25rem; align-self: flex-start; transition: background 0.2s, color 0.2s; }
    .prog-cta:hover { background: var(--blue); color: #fff; }

    /* ── AGENTEXIT / OPTIQOS section (white) ── */
    .optiqos { background: var(--light2); padding: 7rem 0; border-bottom: 1px solid var(--light3); }
    .optiqos-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; }
    .optiqos-chip { display: inline-flex; align-items: center; gap: 0.5rem; background: transparent; border: 1px solid var(--blue); color: var(--blue); font-family: var(--font-nav); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; padding: 0.35rem 0.9rem; border-radius: 0; margin-bottom: 1.5rem; }
    .optiqos h2 { font-family: var(--serif); font-weight: 300; font-size: clamp(1.9rem, 3vw, 2.8rem); color: var(--ink); margin-bottom: 0.6rem; line-height: 1.15; }
    .optiqos h2 em { font-style: normal; color: var(--blue); }
    .optiqos-sub { font-family: var(--font-nav); font-size: 0.85rem; color: var(--blue); font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 1.5rem; }
    .optiqos p { font-size: 0.95rem; color: var(--ink); line-height: 1.8; font-weight: 400; margin-bottom: 1.1rem; }
    .feature-list { list-style: none; margin-top: 2rem; display: flex; flex-direction: column; border-top: 1.5px solid var(--light3); padding-top: 1.25rem; }
    .feature-list li { display: flex; align-items: flex-start; gap: 1rem; padding: 1rem 0; border-bottom: 1px solid var(--light3); font-size: 0.9rem; }
    .feature-list li:last-child { border-bottom: none; }
    .feat-num { font-family: var(--serif); font-weight: 300; font-size: 1.3rem; color: var(--blue); width: 1.6rem; flex-shrink: 0; margin-top: 0.05rem; }
    .feat-text strong { display: block; font-size: 0.9rem; font-weight: 600; color: var(--ink); margin-bottom: 0.25rem; }
    .feat-text span { font-size: 0.85rem; color: var(--gray); font-weight: 400; line-height: 1.55; }
    .optiqos-visual { position: sticky; top: 6rem; }
    .stat-display { background: var(--light); border: 1px solid var(--light3); padding: 2.25rem; }
    .stat-display-head { font-family: var(--font-nav); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gray); margin-bottom: 1.5rem; }
    .stat-display-items { display: flex; flex-direction: column; gap: 0.85rem; }
    .sdi { display: flex; align-items: center; justify-content: space-between; padding: 0.95rem 1.2rem; background: #fff; border: 1px solid var(--light3); }
    .sdi-label { font-size: 0.8rem; font-weight: 500; color: var(--ink); }
    .sdi-value { font-family: var(--serif); font-weight: 400; font-size: 1.35rem; color: var(--blue); }
    .sdi-delta { font-family: var(--font-nav); font-size: 0.65rem; font-weight: 600; color: #1B7332; background: rgba(34,197,94,0.1); padding: 0.18rem 0.55rem; border-radius: 100px; letter-spacing: 0.04em; }
    .sdi-delta.warn { color: var(--amber-rare); background: rgba(170,85,0,0.1); }
    .sdi-right { display: flex; align-items: center; gap: 0.5rem; }
    .insight-light { margin-top: 1.25rem; background: rgba(67,129,195,0.08); border-left: 3px solid var(--blue); padding: 0.95rem 1.15rem; font-size: 0.85rem; color: var(--ink); line-height: 1.6; }
    .insight-light strong { color: var(--blue); }

    /* ── QUOTES (light gray) ── */
    .quotes { background: var(--light); padding: 6.5rem 0; border-top: 1px solid var(--light3); border-bottom: 1px solid var(--light3); }
    .quotes .section-eyebrow { color: var(--blue); }
    .quotes .section-heading { color: var(--ink); }
    .quotes .section-heading em { color: var(--blue); }
    .quotes-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
    .quote-card { background: #fff; border: 1px solid var(--light3); padding: 2.5rem; }
    .q-mark { font-family: var(--serif); font-weight: 300; font-size: 4rem; line-height: 0.6; color: var(--blue); opacity: 0.45; margin-bottom: 1.25rem; }
    .q-text { font-family: var(--serif); font-style: italic; font-weight: 400; font-size: 1rem; color: var(--ink); line-height: 1.65; margin-bottom: 1.5rem; }
    .q-outcome { font-family: var(--font-nav); font-size: 0.72rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--blue); display: flex; align-items: center; gap: 0.4rem; margin-bottom: 1.25rem; }
    .q-outcome::before { content: '\2192'; }
    .q-attr { display: flex; align-items: center; gap: 0.85rem; border-top: 1px solid var(--light3); padding-top: 1rem; }
    .q-headshot { width: 42px; height: 42px; border-radius: 50%; object-fit: cover; flex-shrink: 0; filter: grayscale(0.45); border: 1px solid var(--light3); background: var(--light3); }
    .q-meta { flex: 1; min-width: 0; }
    .q-name { font-size: 0.82rem; font-weight: 600; color: var(--ink); }
    .q-role { font-size: 0.72rem; color: var(--gray); font-weight: 400; margin-top: 0.1rem; }

    /* ── PROCESS (white) ── */
    .process { background: var(--light2); padding: 7rem 0; border-bottom: 1px solid var(--light3); }
    .process .section-eyebrow { color: var(--blue); }
    .process .section-heading { color: var(--ink); }
    .process .section-heading em { color: var(--blue); }
    .steps-light { display: grid; grid-template-columns: repeat(3, 1fr); gap: 4rem; }
    .step-l { position: relative; }
    .step-l-num { font-family: var(--serif); font-weight: 300; font-size: 2.6rem; color: var(--blue); opacity: 0.4; line-height: 1; margin-bottom: 0.85rem; }
    .step-l h3 { font-family: var(--sans); font-size: 1.1rem; color: var(--ink); margin-bottom: 0.7rem; font-weight: 600; letter-spacing: -0.005em; }
    .step-l p { font-size: 0.92rem; color: var(--gray); line-height: 1.75; font-weight: 400; }

    /* ── Responsive ──────────────────────────────────────────────────── */
    @media (max-width: 960px) {
      .optiqos-inner, .programs-grid, .steps-light, .quotes-grid, .wn-stats { grid-template-columns: 1fr; }
      .wn-stat:not(:last-child)::after { display: none; }
      .proof-name { display: none; }
      .optiqos-visual { position: static; }
    }
  </style>

  <!-- HERO (Joe 2026-05-05 copy) -->
  <section class="hero" id="top">
    <div class="container">
      <div class="hero-chip">The Exit Agency for Owner-Operators</div>
      <h1 class="hero-headline">
        Max your <span class="hero-emph">exit.</span>
      </h1>
      <p class="hero-sub fade-in">
        You get paid to work your business, but are you ready to get paid not to? At Conversiv, we&rsquo;re here to get you there. We help you position your business for a max selling price.
      </p>
      <div class="hero-actions fade-in">
        <a href="/start" class="btn-ink">Free exit audit &rarr;</a>
        <a href="/demo" class="btn-outline">Book your demo</a>
      </div>
      <p class="magic-link-hint fade-in"><strong>No password required.</strong> We&rsquo;ll send a magic link to your inbox.</p>
      <div class="hero-proof fade-in">
        <span class="hero-proof-label">Built by leaders from</span>
        <div class="hero-proof-names">
          <span class="proof-name">Microsoft</span>
          <span class="proof-name">Cisco</span>
          <span class="proof-name">Yum! Brands</span>
          <span class="proof-name">LifeLock</span>
          <span class="proof-name">Samuel Adams</span>
        </div>
      </div>
    </div>
  </section>

  <!-- PROOF MARQUEE (black band) -->
  <div class="proof-marquee">
    <div class="proof-track">
      <span class="proof-item">Microsoft <span class="proof-dot">&bull;</span></span>
      <span class="proof-item">Cisco <span class="proof-dot">&bull;</span></span>
      <span class="proof-item">Yum! Brands <span class="proof-dot">&bull;</span></span>
      <span class="proof-item">LifeLock <span class="proof-dot">&bull;</span></span>
      <span class="proof-item">Samuel Adams <span class="proof-dot">&bull;</span></span>
      <span class="proof-item">Avnet <span class="proof-dot">&bull;</span></span>
      <span class="proof-item">Sylvan <span class="proof-dot">&bull;</span></span>
      <span class="proof-item">The Exit Agency <span class="proof-dot">&bull;</span></span>
      <span class="proof-item">Get more sooner <span class="proof-dot">&bull;</span></span>
      <span class="proof-item">Microsoft <span class="proof-dot">&bull;</span></span>
      <span class="proof-item">Cisco <span class="proof-dot">&bull;</span></span>
      <span class="proof-item">Yum! Brands <span class="proof-dot">&bull;</span></span>
      <span class="proof-item">LifeLock <span class="proof-dot">&bull;</span></span>
      <span class="proof-item">Samuel Adams <span class="proof-dot">&bull;</span></span>
      <span class="proof-item">Avnet <span class="proof-dot">&bull;</span></span>
      <span class="proof-item">Sylvan <span class="proof-dot">&bull;</span></span>
      <span class="proof-item">The Exit Agency <span class="proof-dot">&bull;</span></span>
      <span class="proof-item">Get more sooner <span class="proof-dot">&bull;</span></span>
    </div>
  </div>

  <!-- PILLAR (white) — Joe's section 2 verbatim -->
  <section class="pillar">
    <div class="container">
      <div class="pillar-inner fade-in">
        <span class="pillar-eyebrow">The Conversiv pillar</span>
        <h2>Get more for your business <em>sooner.</em></h2>
        <p>How? By using smarter strategy and technology to better connect you to your audiences and your operations. This allows you to optimize your revenue, and minimize wasted time, effort and money. We&rsquo;ll show you how.</p>
        <div class="pillar-cta">
          <a href="/start" class="btn-ink">Free exit audit &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- AUTHORITY QUOTE (light gray) -->
  <section class="authority-quote">
    <div class="container">
      <div class="aq-inner fade-in">
        <span class="aq-eyebrow">From the field</span>
        <blockquote class="aq-text">
          &ldquo;The number one driver of price variance at the table isn&rsquo;t EBITDA. It&rsquo;s the story.&rdquo;
        </blockquote>
        <div class="aq-attr">
          <div class="aq-name">Sell-side M&amp;A advisor</div>
          <div class="aq-role">Lower middle market, $5M to $50M deals</div>
        </div>
      </div>
    </div>
  </section>

  <!-- EDITORIAL IMAGE BREAK (black + photo) -->
  <section class="editorial-break">
    <img src="https://images.unsplash.com/photo-1521737711867-e3b97375f902?w=1800&q=85&auto=format&fit=crop" alt="Owners and operators in conversation" />
    <div class="editorial-overlay">
      <div class="editorial-overlay-inner">
        <div class="editorial-eyebrow">For owner-operators</div>
        <p class="editorial-quote">You built it from nothing.<br />You should get every dollar it&rsquo;s <em>worth.</em></p>
        <div class="editorial-attr">Conversiv founding principle</div>
      </div>
    </div>
  </section>

  <!-- WHY CONNECT WITH CONVERSIV (light gray) — Joe's section 3 -->
  <section class="why-now" id="why">
    <div class="container">
      <div class="wn-header fade-in">
        <span class="wn-eyebrow">Why connect with Conversiv</span>
        <h2 class="wn-heading">The clock is <em>real.</em></h2>
      </div>
      <div class="wn-stats">
        <div class="wn-stat fade-in">
          <div class="wn-stat-num">70%</div>
          <div class="wn-stat-label">of small businesses listed for sale don&rsquo;t close</div>
        </div>
        <div class="wn-stat fade-in">
          <div class="wn-stat-num">75%</div>
          <div class="wn-stat-label">of owners who do sell regret it within 12 months</div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROGRAMS (BLACK — audit "feature sections solid black") -->
  <section class="programs" id="programs">
    <div class="container">
      <span class="section-eyebrow">How we work</span>
      <h2 class="section-heading fade-in">Two ways to work with us.</h2>
      <div class="programs-grid">
        <div class="prog-card fade-in">
          <div class="prog-num">01</div>
          <h3>Accelerate</h3>
          <p class="prog-sub">For owners 12 to 36 months from selling</p>
          <p>You know you&rsquo;ll sell. It&rsquo;s just not next year. Accelerate sharpens how your business shows up to a buyer, plugs into your numbers, and tells you exactly what to fix to grow your multiple. So when you&rsquo;re ready, you&rsquo;re ready.</p>
          <ul class="prog-features">
            <li>Exit Message Audit</li>
            <li>Multiple Map (your roadmap)</li>
            <li>AgentExit business view</li>
