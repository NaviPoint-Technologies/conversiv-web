---
const title = "Conversiv";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="Conversiv — coming soon." />
    <style>
      :root {
        --bg: #0b1020;
        --fg: #f5f7ff;
        --accent: #4f8cff;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { height: 100%; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        background: linear-gradient(135deg, var(--bg) 0%, #1a2342 100%);
        color: var(--fg);
        display: grid;
        place-items: center;
        text-align: center;
        padding: 2rem;
      }
      h1 { font-size: clamp(2.5rem, 8vw, 5rem); font-weight: 800; letter-spacing: -0.03em; }
      p  { margin-top: 1rem; opacity: 0.75; font-size: 1.125rem; }
      .accent { color: var(--accent); }
    </style>
  </head>
  <body>
    <main>
      <h1>Convers<span class="accent">iv</span></h1>
      <p>Something new is on the way.</p>
    </main>
  </body>
</html>
