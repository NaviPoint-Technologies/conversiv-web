---
const title = "Conversiv — The Exit Agency";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="Conversiv is the exit agency for small business. We optimize your message and operations to maximize your value when it's time to sell." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style>
      /* ── Reset & Root ─────────────────────────────────────────── */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root {
        --navy:   #09111F;
        --navy2:  #0F1B2E;
        --navy3:  #162438;
        --gold:   #C89A3A;
        --gold2:  #E3B44B;
        --cream:  #F7F4EE;
        --white:  #FDFCF9;
        --gray:   #7B8299;
        --gray2:  #B4BAC8;
        --serif:  'Playfair Display', Georgia, serif;
        --sans:   'Inter', -apple-system, sans-serif;
      }
      html { scroll-behavior: smooth; }
      body {
        font-family: var(--sans);
        background: var(--navy);
        color: var(--cream);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      /* ── Typography ───────────────────────────────────────────── */
      h1, h2, h3 { font-family: var(--serif); line-height: 1.1; }
      a { color: inherit; text-decoration: none; }

      /* ── Layout helpers ───────────────────────────────────────── */
      .container { max-width: 1160px; margin: 0 auto; padding: 0 2rem; }
      .container--wide { max-width: 1360px; margin: 0 auto; padding: 0 2rem; }
      section { padding: 7rem 0; }

      /* ── Gold rule ────────────────────────────────────────────── */
      .rule {
        display: inline-block;
        width: 48px; height: 2px;
        background: var(--gold);
        margin-bottom: 1.5rem;
      }

      /* ── NAV ──────────────────────────────────────────────────── */
      nav {
        position: fixed; top: 0; left: 0; right: 0; z-index: 100;
        padding: 1.5rem 0;
        transition: background 0.3s, padding 0.3s, backdrop-filter 0.3s;
      }
      nav.scrolled {
        background: rgba(9, 17, 31, 0.92);
        backdrop-filter: blur(12px);
        padding: 1rem 0;
        border-bottom: 1px solid rgba(200, 154, 58, 0.15);
      }
      .nav-inner {
        display: flex; align-items: center; justify-content: space-between;
      }
      .nav-logo {
        font-family: var(--serif);
        font-size: 1.35rem;
        font-weight: 700;
        letter-spacing: -0.01em;
        color: var(--white);
      }
      .nav-logo span { color: var(--gold); }
      .nav-links {
        display: flex; gap: 2.5rem; list-style: none;
        font-size: 0.875rem; font-weight: 500; letter-spacing: 0.04em;
        text-transform: uppercase; color: var(--gray2);
      }
      .nav-links a:hover { color: var(--gold); transition: color 0.2s; }
      .nav-cta {
        font-size: 0.875rem; font-weight: 500;
        color: var(--navy);
        background: var(--gold);
        padding: 0.6rem 1.4rem;
        border-radius: 3px;
        letter-spacing: 0.02em;
        transition: background 0.2s, transform 0.15s;
      }
      .nav-cta:hover { background: var(--gold2); transform: translateY(-1px); }

      /* ── HERO ─────────────────────────────────────────────────── */
      .hero {
        min-height: 100vh;
        display: flex; flex-direction: column; justify-content: center;
        padding: 10rem 0 6rem;
        background:
          radial-gradient(ellipse 80% 60% at 60% 40%, rgba(200,154,58,0.06) 0%, transparent 70%),
          linear-gradient(160deg, #09111F 0%, #0C1628 50%, #09111F 100%);
        border-bottom: 1px solid rgba(200,154,58,0.12);
        position: relative;
        overflow: hidden;
      }
      .hero::before {
        content: '';
        position: absolute; inset: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23C89A3A' fill-opacity='0.025'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        opacity: 0.4;
      }
      .hero-label {
        font-size: 0.75rem; font-weight: 600; letter-spacing: 0.2em;
        text-transform: uppercase; color: var(--gold);
        margin-bottom: 1.75rem;
        display: flex; align-items: center; gap: 0.75rem;
      }
      .hero-label::before {
        content: ''; display: inline-block;
        width: 32px; height: 1px; background: var(--gold);
      }
      h1.hero-headline {
        font-size: clamp(3.5rem, 8vw, 6.5rem);
        font-weight: 900;
        letter-spacing: -0.02em;
        line-height: 1.0;
        color: var(--white);
        max-width: 820px;
        margin-bottom: 2rem;
      }
      h1.hero-headline em {
        font-style: italic;
        color: var(--gold);
      }
      .hero-sub {
        font-size: 1.2rem;
        font-weight: 300;
        color: var(--gray2);
        max-width: 520px;
        line-height: 1.7;
        margin-bottom: 3rem;
      }
      .hero-sub strong { color: var(--cream); font-weight: 500; }
      .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
      .btn-primary {
        display: inline-flex; align-items: center; gap: 0.5rem;
        background: var(--gold); color: var(--navy);
        padding: 1rem 2rem; border-radius: 3px;
        font-size: 0.95rem; font-weight: 600; letter-spacing: 0.02em;
        transition: background 0.2s, transform 0.15s;
      }
      .btn-primary:hover { background: var(--gold2); transform: translateY(-2px); }
      .btn-ghost {
        display: inline-flex; align-items: center; gap: 0.5rem;
        border: 1px solid rgba(200,154,58,0.35); color: var(--gold);
        padding: 1rem 2rem; border-radius: 3px;
        font-size: 0.95rem; font-weight: 500; letter-spacing: 0.02em;
        transition: border-color 0.2s, background 0.2s;
      }
      .btn-ghost:hover { border-color: var(--gold); background: rgba(200,154,58,0.06); }
      .hero-scroll {
        margin-top: 5rem;
        font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase;
        color: var(--gray); display: flex; align-items: center; gap: 0.75rem;
      }
      .hero-scroll::after {
        content: ''; display: inline-block;
        width: 1px; height: 40px; background: var(--gray);
      }

      /* ── POSITIONING STRIP ────────────────────────────────────── */
      .strip {
        background: var(--navy2);
        padding: 5rem 0;
        border-top: 1px solid rgba(200,154,58,0.1);
        border-bottom: 1px solid rgba(200,154,58,0.1);
      }
      .strip-inner {
        display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center;
      }
      .strip-left {
        font-family: var(--serif);
        font-size: clamp(1.6rem, 2.5vw, 2.2rem);
        font-weight: 400;
        line-height: 1.4;
        color: var(--white);
      }
      .strip-left em { font-style: italic; color: var(--gold); }
      .strip-right {
        font-size: 1rem; font-weight: 300; color: var(--gray2); line-height: 1.8;
        border-left: 1px solid rgba(200,154,58,0.2);
        padding-left: 3rem;
      }
      .strip-right strong { color: var(--cream); font-weight: 500; }

      /* ── SERVICES ─────────────────────────────────────────────── */
      .services { background: var(--navy); }
      .section-header { margin-bottom: 4rem; }
      .section-label {
        font-size: 0.72rem; font-weight: 600; letter-spacing: 0.2em;
        text-transform: uppercase; color: var(--gold);
        margin-bottom: 1rem; display: block;
      }
      .section-title {
        font-size: clamp(2rem, 3.5vw, 2.8rem);
        font-weight: 700; color: var(--white); max-width: 600px;
      }
      .services-grid {
        display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5px;
        background: rgba(200,154,58,0.1);
        border: 1px solid rgba(200,154,58,0.1);
      }
      .service-card {
        background: var(--navy);
        padding: 3rem;
        transition: background 0.25s;
      }
      .service-card:hover { background: var(--navy2); }
      .service-num {
        font-family: var(--serif); font-size: 0.9rem;
        color: var(--gold); font-style: italic;
        margin-bottom: 1.5rem; display: block;
      }
      .service-icon {
        width: 44px; height: 44px; margin-bottom: 1.75rem;
        background: rgba(200,154,58,0.1); border-radius: 3px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem;
      }
      .service-card h3 {
        font-family: var(--serif);
        font-size: 1.5rem; font-weight: 700;
        color: var(--white); margin-bottom: 1rem;
      }
      .service-card p {
        font-size: 0.95rem; color: var(--gray2);
        line-height: 1.75; font-weight: 300;
      }
      .service-card ul {
        list-style: none; margin-top: 1.5rem;
      }
      .service-card ul li {
        font-size: 0.875rem; color: var(--gray);
        padding: 0.4rem 0;
        border-top: 1px solid rgba(255,255,255,0.05);
        display: flex; align-items: center; gap: 0.6rem;
      }
      .service-card ul li::before {
        content: '→'; color: var(--gold); font-size: 0.75rem;
        flex-shrink: 0;
      }

      /* ── OPTIQOS FEATURE ─────────────────────────────────────── */
      .agentx {
        background: var(--navy2);
        border-top: 1px solid rgba(200,154,58,0.1);
        border-bottom: 1px solid rgba(200,154,58,0.1);
      }
      .agentx-inner {
        display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: center;
      }
      .agentx-tag {
        display: inline-flex; align-items: center; gap: 0.5rem;
        background: rgba(200,154,58,0.1); border: 1px solid rgba(200,154,58,0.25);
        color: var(--gold); font-size: 0.72rem; font-weight: 600;
        letter-spacing: 0.15em; text-transform: uppercase;
        padding: 0.4rem 0.9rem; border-radius: 2px;
        margin-bottom: 1.75rem; width: fit-content;
      }
      .agentx h2 {
        font-size: clamp(2rem, 3vw, 2.75rem);
        font-weight: 700; color: var(--white);
        margin-bottom: 1.5rem; line-height: 1.15;
      }
      .agentx h2 em { font-style: italic; color: var(--gold); }
      .agentx p {
        font-size: 1rem; color: var(--gray2); line-height: 1.8;
        font-weight: 300; margin-bottom: 1.5rem;
      }
      .agentx-features {
        display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 2.5rem;
      }
      .agentx-feat {
        background: rgba(200,154,58,0.05); border: 1px solid rgba(200,154,58,0.12);
        padding: 1.25rem 1.5rem; border-radius: 3px;
      }
      .agentx-feat-icon { font-size: 1.2rem; margin-bottom: 0.5rem; }
      .agentx-feat-label {
        font-size: 0.8rem; font-weight: 600; letter-spacing: 0.06em;
        text-transform: uppercase; color: var(--cream);
      }
      .agentx-feat-desc {
        font-size: 0.8rem; color: var(--gray); margin-top: 0.25rem; line-height: 1.5;
      }
      .agentx-visual {
        background: var(--navy3);
        border: 1px solid rgba(200,154,58,0.15);
        border-radius: 6px; padding: 2.5rem;
        position: relative;
      }
      .dashboard-bar {
        background: rgba(200,154,58,0.08);
        border-bottom: 1px solid rgba(200,154,58,0.12);
        padding: 0.75rem 1rem;
        margin: -2.5rem -2.5rem 2rem -2.5rem;
        border-radius: 6px 6px 0 0;
        display: flex; align-items: center; gap: 0.5rem;
      }
      .dot { width: 10px; height: 10px; border-radius: 50%; }
      .dot.r { background: #FF5F57; }
      .dot.y { background: #FEBC2E; }
      .dot.g { background: #28C840; }
      .dashboard-title {
        margin-left: auto; margin-right: auto;
        font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase;
        color: var(--gray);
      }
      .metric-row {
        display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem;
      }
      .metric {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 4px; padding: 1rem;
      }
      .metric-label { font-size: 0.7rem; color: var(--gray); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 0.25rem; }
      .metric-value { font-size: 1.4rem; font-weight: 600; color: var(--white); font-family: var(--serif); }
      .metric-delta { font-size: 0.7rem; color: #4ADE80; margin-top: 0.15rem; }
      .metric-delta.down { color: #F87171; }
      .bar-chart {
        margin-top: 1.5rem; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 1.5rem;
      }
      .bar-chart-label { font-size: 0.7rem; color: var(--gray); margin-bottom: 1rem; letter-spacing: 0.08em; text-transform: uppercase; }
      .bars { display: flex; align-items: flex-end; gap: 6px; height: 60px; }
      .bar {
        flex: 1; background: rgba(200,154,58,0.25); border-radius: 2px 2px 0 0;
        transition: height 0.3s;
      }
      .bar.hi { background: var(--gold); }
      .insight-strip {
        margin-top: 1.5rem; background: rgba(74,222,128,0.06);
        border: 1px solid rgba(74,222,128,0.2); border-radius: 4px;
        padding: 0.75rem 1rem;
        font-size: 0.78rem; color: #4ADE80;
      }
      .insight-strip strong { color: #6EE7A8; }

      /* ── HOW IT WORKS ─────────────────────────────────────────── */
      .how { background: var(--navy); }
      .steps {
        display: grid; grid-template-columns: repeat(3, 1fr); gap: 3rem;
        position: relative;
      }
      .steps::before {
        content: '';
        position: absolute; top: 1.5rem; left: calc(16.66% + 1rem); right: calc(16.66% + 1rem);
        height: 1px; background: linear-gradient(90deg, var(--gold) 0%, rgba(200,154,58,0.1) 100%);
      }
      .step { position: relative; }
      .step-num {
        width: 3rem; height: 3rem; border-radius: 50%;
        border: 1px solid var(--gold);
        display: flex; align-items: center; justify-content: center;
        font-family: var(--serif); font-size: 1rem; color: var(--gold);
        font-style: italic; margin-bottom: 1.75rem;
        background: var(--navy);
        position: relative; z-index: 1;
      }
      .step h3 {
        font-size: 1.2rem; color: var(--white); margin-bottom: 0.75rem;
        font-weight: 700;
      }
      .step p {
        font-size: 0.9rem; color: var(--gray2); line-height: 1.75; font-weight: 300;
      }

      /* ── WHO IT'S FOR ─────────────────────────────────────────── */
      .who {
        background: linear-gradient(160deg, var(--navy2) 0%, var(--navy3) 100%);
        border-top: 1px solid rgba(200,154,58,0.1);
        border-bottom: 1px solid rgba(200,154,58,0.1);
      }
      .who-inner {
        display: grid; grid-template-columns: 1.2fr 1fr; gap: 6rem; align-items: center;
      }
      .who h2 {
        font-size: clamp(2rem, 3vw, 2.75rem);
        font-weight: 700; color: var(--white); line-height: 1.2; margin-bottom: 1.5rem;
      }
      .who h2 em { font-style: italic; color: var(--gold); }
      .who-lead {
        font-size: 1rem; color: var(--gray2); line-height: 1.85; font-weight: 300;
      }
      .fit-list {
        list-style: none;
        border: 1px solid rgba(200,154,58,0.12);
        background: rgba(200,154,58,0.03);
        border-radius: 4px;
        overflow: hidden;
      }
      .fit-list li {
        display: flex; align-items: flex-start; gap: 1rem;
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid rgba(200,154,58,0.08);
        font-size: 0.9rem; color: var(--cream); line-height: 1.6;
      }
      .fit-list li:last-child { border-bottom: none; }
      .fit-list li::before {
        content: '✓';
        color: var(--gold); font-weight: 700;
        flex-shrink: 0; margin-top: 0.1rem;
      }

      /* ── CTA ──────────────────────────────────────────────────── */
      .cta-section {
        padding: 8rem 0;
        background: var(--navy);
        text-align: center;
        border-top: 1px solid rgba(200,154,58,0.1);
      }
      .cta-section h2 {
        font-size: clamp(2.5rem, 5vw, 4rem);
        color: var(--white); max-width: 680px; margin: 0 auto 1.5rem;
        line-height: 1.1;
      }
      .cta-section h2 em { font-style: italic; color: var(--gold); }
      .cta-section p {
        font-size: 1.05rem; color: var(--gray2); max-width: 440px;
        margin: 0 auto 2.5rem; font-weight: 300; line-height: 1.7;
      }
      .cta-actions { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; }
      .cta-footnote {
        margin-top: 2rem; font-size: 0.8rem; color: var(--gray);
        letter-spacing: 0.04em;
      }

      /* ── FOOTER ───────────────────────────────────────────────── */
      footer {
        background: #060C16;
        padding: 3rem 0;
        border-top: 1px solid rgba(200,154,58,0.1);
      }
      .footer-inner {
        display: flex; align-items: center; justify-content: space-between;
        flex-wrap: wrap; gap: 1.5rem;
      }
      .footer-logo {
        font-family: var(--serif); font-size: 1.1rem;
        font-weight: 700; color: var(--white);
      }
      .footer-logo span { color: var(--gold); }
      .footer-tagline {
        font-size: 0.75rem; color: var(--gray);
        letter-spacing: 0.1em; text-transform: uppercase; margin-top: 0.35rem;
      }
      .footer-links {
        display: flex; gap: 2rem; list-style: none;
        font-size: 0.8rem; color: var(--gray);
        letter-spacing: 0.06em; text-transform: uppercase;
      }
      .footer-links a:hover { color: var(--gold2); transition: color 0.2s; }
      .footer-copy { font-size: 0.75rem; color: var(--gray); }

      /* ── Responsive ───────────────────────────────────────────── */
      @media (max-width: 900px) {
        .strip-inner, .agentx-inner, .who-inner { grid-template-columns: 1fr; gap: 3rem; }
        .strip-right { border-left: none; padding-left: 0; border-top: 1px solid rgba(200,154,58,0.2); padding-top: 2rem; }
        .services-grid { grid-template-columns: 1fr; }
        .steps { grid-template-columns: 1fr; }
        .steps::before { display: none; }
        .nav-links, .nav-cta { display: none; }
        .agentx-visual { display: none; }
        .agentx-inner { grid-template-columns: 1fr; }
        .agentx-features { grid-template-columns: 1fr 1fr; }
        .who-inner { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>

    <!-- NAV -->
    <nav id="nav">
      <div class="container">
        <div class="nav-inner">
          <a href="/" class="nav-logo">Convers<span>iv</span></a>
          <ul class="nav-links">
            <li><a href="#services">Services</a></li>
            <li><a href="#agentx">OptiqOS</a></li>
            <li><a href="#how">How It Works</a></li>
          </ul>
          <a href="mailto:hello@conversiv.com" class="nav-cta">Get Started</a>
        </div>
      </div>
    </nav>

    <!-- HERO -->
    <section class="hero" id="top">
      <div class="container">
        <div class="hero-label">The Exit Agency</div>
        <h1 class="hero-headline">
          Ready to get paid<br /><em>not to work?</em>
        </h1>
        <p class="hero-sub">
          You built something valuable. Conversiv helps you <strong>prove it</strong> — by optimizing your message, your operations, and your spend so your business is worth more when it's time to sell.
        </p>
        <div class="hero-actions">
          <a href="#how" class="btn-primary">See how it works →</a>
          <a href="mailto:hello@conversiv.com" class="btn-ghost">Book a conversation</a>
        </div>
        <div class="hero-scroll">Scroll to explore</div>
      </div>
    </section>

    <!-- POSITIONING STRIP -->
    <div class="strip">
      <div class="container">
        <div class="strip-inner">
          <div class="strip-left">
            We're not a growth agency.<br />
            We're your <em>exit strategy.</em>
          </div>
          <div class="strip-right">
            Most agencies optimize for revenue. We optimize for <strong>enterprise value</strong> — the number that matters when you sell. That means sharper positioning, cleaner operations, and a business that buyers pay a premium for.
            <br /><br />
            <strong>Conversiv is the better way for small business owners who are building toward exit.</strong>
          </div>
        </div>
      </div>
    </div>

    <!-- SERVICES -->
    <section class="services" id="services">
      <div class="container">
        <div class="section-header">
          <span class="section-label">What We Optimize</span>
          <h2 class="section-title">Three levers. One objective: maximum exit value.</h2>
        </div>
        <div class="services-grid">
          <div class="service-card">
            <span class="service-num">01</span>
            <div class="service-icon">✦</div>
            <h3>Message & Positioning</h3>
            <p>Your message is either building your exit price or costing you one. We sharpen how you communicate your value to customers, buyers, and the market.</p>
            <ul>
              <li>Brand positioning strategy</li>
              <li>Messaging architecture</li>
              <li>Competitive differentiation</li>
              <li>Digital presence audit</li>
            </ul>
          </div>
          <div class="service-card">
            <span class="service-num">02</span>
            <div class="service-icon">◈</div>
            <h3>Operations & Insights</h3>
            <p>Buyers pay for businesses that run without the owner. We connect your digital tools and surface the insights that drive operational efficiency and scalable growth.</p>
            <ul>
              <li>Business intelligence dashboard</li>
              <li>KPI identification & tracking</li>
