---
const title = "Conversiv — The Exit Agency";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="Conversiv optimizes your message and operations to maximize your value for exit, so you can get more for your business sooner." />
    <link rel="icon" type="image/svg+xml" href="/conversiv-mark.svg" />
    <link rel="apple-touch-icon" href="/conversiv-mark.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet" />
    <style>
      /* ── Reset & Root ─────────────────────────────────────────── */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root {
        --navy:   #1A2D45;
        --navy2:  #223655;
        --navy3:  #285072;
        --orange: #F18A00;
        --orange2:#FF9E1B;
        --blue:   #4381C3;
        --cream:  #F7F6F2;
        --white:  #FFFFFF;
        --gray:   #7B8299;
        --gray2:  #A8B0BF;
        --serif:  'Playfair Display', Georgia, serif;
        --sans:   'Roboto', -apple-system, sans-serif;
      }
      html { scroll-behavior: smooth; }
      body {
        font-family: var(--sans);
        background: var(--navy);
        color: var(--cream);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }
      h1, h2, h3 { font-family: var(--serif); line-height: 1.1; }
      a { color: inherit; text-decoration: none; }
      .container { max-width: 1160px; margin: 0 auto; padding: 0 2rem; }

      /* ── NAV ──────────────────────────────────────────────────── */
      nav {
        position: fixed; top: 0; left: 0; right: 0; z-index: 100;
        padding: 1.5rem 0;
        transition: background 0.3s, padding 0.3s, backdrop-filter 0.3s;
      }
      nav.scrolled {
        background: rgba(26, 45, 69, 0.95);
        backdrop-filter: blur(12px);
        padding: 1rem 0;
        border-bottom: 1px solid rgba(241, 138, 0, 0.15);
      }
      .nav-inner {
        display: flex; align-items: center; justify-content: space-between;
      }
      .nav-logo { display: flex; align-items: center; }
      .nav-logo img { height: 26px; width: auto; }
      .nav-links {
        display: flex; gap: 2.5rem; list-style: none;
        font-size: 0.8rem; font-weight: 500; letter-spacing: 0.08em;
        text-transform: uppercase; color: var(--gray2);
      }
      .nav-links a:hover { color: var(--orange); transition: color 0.2s; }
      .nav-cta {
        font-size: 0.8rem; font-weight: 700; letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--navy);
        background: var(--orange);
        padding: 0.65rem 1.5rem;
        border-radius: 2px;
        transition: background 0.2s, transform 0.15s;
      }
      .nav-cta:hover { background: var(--orange2); transform: translateY(-1px); }

      /* ── HERO ─────────────────────────────────────────────────── */
      .hero {
        min-height: 100vh;
        display: flex; flex-direction: column; justify-content: center;
        padding: 10rem 0 5rem;
        background:
          radial-gradient(ellipse 70% 50% at 65% 40%, rgba(241,138,0,0.06) 0%, transparent 70%),
          linear-gradient(160deg, #1A2D45 0%, #1E3352 60%, #1A2D45 100%);
        border-bottom: 1px solid rgba(241,138,0,0.12);
        position: relative; overflow: hidden;
      }
      .hero::before {
        content: '';
        position: absolute; inset: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23F18A00' fill-opacity='0.02' fill-rule='evenodd'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/svg%3E");
      }
      .hero-eyebrow {
        display: flex; align-items: center; gap: 0.75rem;
        font-size: 0.72rem; font-weight: 700; letter-spacing: 0.2em;
        text-transform: uppercase; color: var(--orange);
        margin-bottom: 2rem;
      }
      .hero-eyebrow::before {
        content: ''; display: inline-block;
        width: 28px; height: 1px; background: var(--orange);
      }
      h1.hero-headline {
        font-size: clamp(2.8rem, 6vw, 5.5rem);
        font-weight: 900; line-height: 1.05;
        letter-spacing: -0.02em;
        color: var(--white);
        max-width: 860px;
        margin-bottom: 1.75rem;
      }
      h1.hero-headline em { font-style: italic; color: var(--orange); }
      .hero-sub {
        font-size: 1.15rem; font-weight: 300;
        color: var(--gray2); max-width: 540px;
        line-height: 1.75; margin-bottom: 2.75rem;
      }
      .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 4rem; }
      .btn-primary {
        display: inline-flex; align-items: center; gap: 0.5rem;
        background: var(--orange); color: var(--navy);
        padding: 1rem 2rem; border-radius: 2px;
        font-size: 0.875rem; font-weight: 700; letter-spacing: 0.06em;
        text-transform: uppercase;
        transition: background 0.2s, transform 0.15s;
      }
      .btn-primary:hover { background: var(--orange2); transform: translateY(-2px); }
      .btn-ghost {
        display: inline-flex; align-items: center; gap: 0.5rem;
        border: 1px solid rgba(241,138,0,0.4); color: var(--orange);
        padding: 1rem 2rem; border-radius: 2px;
        font-size: 0.875rem; font-weight: 500; letter-spacing: 0.04em;
        transition: border-color 0.2s, background 0.2s;
      }
      .btn-ghost:hover { border-color: var(--orange); background: rgba(241,138,0,0.06); }

      /* ── CLIENT LOGO STRIP ────────────────────────────────────── */
      .logos-strip {
        border-top: 1px solid rgba(241,138,0,0.12);
        padding-top: 2.5rem;
      }
      .logos-label {
        font-size: 0.68rem; font-weight: 700; letter-spacing: 0.18em;
        text-transform: uppercase; color: var(--gray);
        margin-bottom: 1.25rem;
      }
      .logos-row {
        display: flex; align-items: center; flex-wrap: wrap; gap: 2rem 3rem;
      }
      .logo-item {
        font-size: 0.8rem; font-weight: 700; letter-spacing: 0.1em;
        text-transform: uppercase; color: var(--gray2);
        opacity: 0.6; transition: opacity 0.2s;
      }
      .logo-item:hover { opacity: 1; }

      /* ── POSITIONING STRIP ────────────────────────────────────── */
      .positioning {
        background: var(--navy2);
        padding: 6rem 0;
        border-top: 1px solid rgba(241,138,0,0.1);
        border-bottom: 1px solid rgba(241,138,0,0.1);
      }
      .pos-inner {
        display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start;
      }
      .pos-left h2 {
        font-size: clamp(1.8rem, 2.8vw, 2.5rem);
        font-weight: 700; color: var(--white); line-height: 1.2; margin-bottom: 1.5rem;
      }
      .pos-left h2 em { font-style: italic; color: var(--orange); }
      .pos-left p {
        font-size: 1rem; color: var(--gray2); line-height: 1.8; font-weight: 300;
      }
      .pos-right {
        border-left: 1px solid rgba(241,138,0,0.2);
        padding-left: 3rem;
      }
      .stat-row {
        display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-bottom: 2rem;
      }
      .stat { }
      .stat-num {
        font-family: var(--serif); font-size: 2.5rem; font-weight: 700;
        color: var(--orange); line-height: 1; margin-bottom: 0.4rem;
      }
      .stat-label {
        font-size: 0.8rem; color: var(--gray2); font-weight: 300; line-height: 1.4;
        letter-spacing: 0.04em;
      }
      .pos-quote {
        font-family: var(--serif); font-style: italic;
        font-size: 1rem; color: var(--cream); line-height: 1.7;
        border-top: 1px solid rgba(241,138,0,0.15);
        padding-top: 1.5rem; margin-top: 0.5rem;
      }
      .pos-quote cite {
        display: block; margin-top: 0.75rem;
        font-style: normal; font-family: var(--sans);
        font-size: 0.72rem; font-weight: 700; letter-spacing: 0.12em;
        text-transform: uppercase; color: var(--orange);
      }

      /* ── PROGRAMS ─────────────────────────────────────────────── */
      .programs { background: var(--navy); padding: 7rem 0; }
      .section-label {
        font-size: 0.72rem; font-weight: 700; letter-spacing: 0.2em;
        text-transform: uppercase; color: var(--orange);
        margin-bottom: 1rem; display: block;
      }
      .section-title {
        font-size: clamp(2rem, 3.5vw, 2.8rem);
        font-weight: 700; color: var(--white); max-width: 640px;
        margin-bottom: 4rem;
      }
      .programs-grid {
        display: grid; grid-template-columns: 1fr 1fr; gap: 2px;
        background: rgba(241,138,0,0.08);
        border: 1px solid rgba(241,138,0,0.1);
      }
      .program-card {
        background: var(--navy);
        padding: 3.5rem;
        transition: background 0.25s;
        position: relative;
      }
      .program-card:hover { background: var(--navy2); }
      .program-tier {
        font-size: 0.68rem; font-weight: 700; letter-spacing: 0.2em;
        text-transform: uppercase; color: var(--orange);
        margin-bottom: 1.75rem; display: flex; align-items: center; gap: 0.6rem;
      }
      .program-tier::before {
        content: ''; display: inline-block;
        width: 20px; height: 1px; background: var(--orange);
      }
      .program-card h3 {
        font-size: 2rem; font-weight: 700; color: var(--white);
        margin-bottom: 0.5rem;
      }
      .program-sub {
        font-size: 0.85rem; color: var(--orange); font-weight: 500;
        letter-spacing: 0.04em; margin-bottom: 1.5rem;
        font-family: var(--sans);
      }
      .program-card p {
        font-size: 0.95rem; color: var(--gray2); line-height: 1.8; font-weight: 300;
        margin-bottom: 2rem;
      }
      .program-features {
        list-style: none; border-top: 1px solid rgba(241,138,0,0.12);
        padding-top: 1.5rem;
      }
      .program-features li {
        font-size: 0.875rem; color: var(--gray2);
        padding: 0.45rem 0;
        border-bottom: 1px solid rgba(255,255,255,0.04);
        display: flex; align-items: center; gap: 0.65rem;
      }
      .program-features li::before { content: '→'; color: var(--orange); font-size: 0.75rem; }
      .program-cta {
        display: inline-flex; align-items: center; gap: 0.4rem;
        margin-top: 2rem;
        font-size: 0.8rem; font-weight: 700; letter-spacing: 0.08em;
        text-transform: uppercase; color: var(--orange);
        border-bottom: 1px solid var(--orange); padding-bottom: 2px;
        transition: color 0.2s, border-color 0.2s;
      }
      .program-cta:hover { color: var(--orange2); border-color: var(--orange2); }

      /* ── OPTIQOS / AGENTX ─────────────────────────────────────── */
      .agentx {
        background: var(--navy2);
        border-top: 1px solid rgba(241,138,0,0.1);
        border-bottom: 1px solid rgba(241,138,0,0.1);
        padding: 7rem 0;
      }
      .agentx-inner {
        display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: center;
      }
      .agentx-tag {
        display: inline-flex; align-items: center; gap: 0.5rem;
        background: rgba(241,138,0,0.08); border: 1px solid rgba(241,138,0,0.25);
        color: var(--orange); font-size: 0.7rem; font-weight: 700;
        letter-spacing: 0.15em; text-transform: uppercase;
        padding: 0.4rem 1rem; border-radius: 2px;
        margin-bottom: 1.75rem; width: fit-content;
      }
      .agentx h2 {
        font-size: clamp(1.8rem, 2.8vw, 2.6rem);
        font-weight: 700; color: var(--white); margin-bottom: 0.5rem; line-height: 1.15;
      }
      .agentx h2 em { font-style: italic; color: var(--orange); }
      .agentx-sub {
        font-size: 1rem; color: var(--orange); font-weight: 500;
        margin-bottom: 1.5rem; letter-spacing: 0.02em;
      }
      .agentx p {
        font-size: 0.975rem; color: var(--gray2); line-height: 1.85;
        font-weight: 300; margin-bottom: 1.5rem;
      }
      .agentx-features {
        display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 2rem;
      }
      .agentx-feat {
        background: rgba(241,138,0,0.04); border: 1px solid rgba(241,138,0,0.12);
        padding: 1.25rem 1.5rem; border-radius: 2px;
      }
      .agentx-feat-icon { font-size: 1.1rem; margin-bottom: 0.4rem; }
      .agentx-feat-label {
        font-size: 0.78rem; font-weight: 700; letter-spacing: 0.06em;
        text-transform: uppercase; color: var(--cream);
      }
      .agentx-feat-desc {
        font-size: 0.78rem; color: var(--gray); margin-top: 0.2rem; line-height: 1.5;
      }
      /* Dashboard mock */
      .agentx-visual {
        background: var(--navy);
        border: 1px solid rgba(241,138,0,0.15);
        border-radius: 4px; padding: 0;
        overflow: hidden;
      }
      .dash-header {
        background: rgba(241,138,0,0.07);
        border-bottom: 1px solid rgba(241,138,0,0.12);
        padding: 0.75rem 1.25rem;
        display: flex; align-items: center; gap: 0.5rem;
      }
      .dash-dot { width: 9px; height: 9px; border-radius: 50%; }
      .dash-dot.r { background: #FF5F57; }
      .dash-dot.y { background: #FEBC2E; }
      .dash-dot.g { background: #28C840; }
      .dash-title {
        margin-left: auto; margin-right: auto;
        font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase;
        color: var(--gray);
      }
      .dash-body { padding: 1.5rem; }
      .metric-row {
        display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; margin-bottom: 1rem;
      }
      .metric {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 3px; padding: 0.9rem 1rem;
      }
      .metric-label { font-size: 0.65rem; color: var(--gray); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 0.2rem; }
      .metric-value { font-size: 1.35rem; font-weight: 700; color: var(--white); font-family: var(--serif); }
      .metric-delta { font-size: 0.65rem; color: #4ADE80; margin-top: 0.1rem; }
      .metric-delta.down { color: #FB923C; }
      .bars-section { margin-top: 0.75rem; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 1rem; }
      .bars-label { font-size: 0.65rem; color: var(--gray); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 0.75rem; }
      .bars { display: flex; align-items: flex-end; gap: 5px; height: 50px; }
      .bar { flex: 1; background: rgba(241,138,0,0.2); border-radius: 1px 1px 0 0; }
      .bar.hi { background: var(--orange); }
      .insight {
        margin-top: 0.75rem; background: rgba(67,129,195,0.08);
        border: 1px solid rgba(67,129,195,0.2); border-radius: 3px;
        padding: 0.65rem 0.9rem;
        font-size: 0.73rem; color: #93C5FD; line-height: 1.5;
      }
      .insight strong { color: #BFDBFE; }

      /* ── PULL QUOTE ───────────────────────────────────────────── */
      .pull-quote {
        background: var(--navy3);
        padding: 6rem 0;
        border-top: 1px solid rgba(241,138,0,0.1);
        border-bottom: 1px solid rgba(241,138,0,0.1);
        text-align: center;
      }
      .pull-quote blockquote {
        font-family: var(--serif); font-style: italic;
        font-size: clamp(1.4rem, 2.5vw, 2rem);
        color: var(--white); max-width: 820px;
        margin: 0 auto; line-height: 1.5;
      }
      .pull-quote blockquote::before {
        content: '\201C';
        display: block; font-size: 4rem; color: var(--orange);
        line-height: 0.6; margin-bottom: 1rem;
      }
      .pull-quote cite {
        display: block; margin-top: 1.5rem;
        font-style: normal; font-family: var(--sans);
        font-size: 0.72rem; font-weight: 700; letter-spacing: 0.18em;
        text-transform: uppercase; color: var(--orange);
      }

      /* ── HOW IT WORKS ─────────────────────────────────────────── */
      .how { background: var(--navy); padding: 7rem 0; }
      .steps {
        display: grid; grid-template-columns: repeat(3, 1fr); gap: 4rem;
        position: relative; margin-top: 1rem;
      }
      .steps::before {
        content: '';
        position: absolute; top: 1.5rem;
        left: calc(16.66% + 1rem); right: calc(16.66% + 1rem);
        height: 1px;
        background: linear-gradient(90deg, rgba(241,138,0,0.6) 0%, rgba(241,138,0,0.1) 100%);
      }
      .step-num {
        width: 3rem; height: 3rem; border-radius: 50%;
        border: 1px solid var(--orange);
        display: flex; align-items: center; justify-content: center;
        font-family: var(--serif); font-size: 1rem; color: var(--orange);
        font-style: italic; margin-bottom: 1.75rem;
        background: var(--navy); position: relative; z-index: 1;
      }
      .step h3 {
        font-size: 1.2rem; color: var(--white); margin-bottom: 0.75rem;
        font-weight: 700;
      }
      .step p { font-size: 0.9rem; color: var(--gray2); line-height: 1.8; font-weight: 300; }

      /* ── CTA ──────────────────────────────────────────────────── */
      .cta-section {
        padding: 8rem 0;
        background: linear-gradient(160deg, var(--navy2) 0%, var(--navy3) 100%);
        border-top: 1px solid rgba(241,138,0,0.12);
        text-align: center;
      }
      .cta-section h2 {
        font-size: clamp(2.5rem, 5vw, 4rem);
        color: var(--white); max-width: 700px; margin: 0 auto 1.5rem;
        line-height: 1.1;
      }
      .cta-section h2 em { font-style: italic; color: var(--orange); }
      .cta-section p {
        font-size: 1rem; color: var(--gray2); max-width: 460px;
        margin: 0 auto 2.5rem; font-weight: 300; line-height: 1.75;
      }
      .cta-actions { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; }
      .cta-footnote { margin-top: 1.75rem; font-size: 0.78rem; color: var(--gray); letter-spacing: 0.06em; }

      /* ── FOOTER ───────────────────────────────────────────────── */
      footer {
        background: #111E2E;
        padding: 3rem 0;
        border-top: 1px solid rgba(241,138,0,0.1);
      }
      .footer-inner {
        display: flex; align-items: center; justify-content: space-between;
        flex-wrap: wrap; gap: 1.5rem;
      }
      .footer-logo img { height: 22px; width: auto; opacity: 0.85; }
      .footer-tagline {
        font-size: 0.7rem; color: var(--gray);
        letter-spacing: 0.1em; text-transform: uppercase; margin-top: 0.4rem;
      }
      .footer-links {
        display: flex; gap: 2rem; list-style: none;
        font-size: 0.75rem; color: var(--gray);
        letter-spacing: 0.06em; text-transform: uppercase;
      }
      .footer-links a:hover { color: var(--orange); transition: color 0.2s; }
      .footer-copy { font-size: 0.72rem; color: var(--gray); }

      /* ── Responsive ───────────────────────────────────────────── */
      @media (max-width: 900px) {
        .pos-inner, .agentx-inner, .programs-grid { grid-template-columns: 1fr; }
        .pos-right { border-left: none; padding-left: 0; border-top: 1px solid rgba(241,138,0,0.2); padding-top: 2rem; }
        .steps { grid-template-columns: 1fr; }
        .steps::before { display: none; }
        .nav-links, .nav-cta { display: none; }
        .agentx-visual { display: none; }
        .agentx-features { grid-template-columns: 1fr 1fr; }
      }
    </style>
  </head>
  <body>

    <!-- NAV -->
    <nav id="nav">
      <div class="container">
        <div class="nav-inner">
          <a href="/" class="nav-logo"><img src="/conversiv-logo.svg" alt="Conversiv" /></a>
          <ul class="nav-links">
            <li><a href="#programs">Our Programs</a></li>
            <li><a href="#agentx">OptiqOS</a></li>
            <li><a href="#how">How It Works</a></li>
            <li><a href="#contact">Contact</a></li>
          </ul>
          <a href="mailto:hello@conversiv.com" class="nav-cta">Get More Sooner</a>
        </div>
      </div>
    </nav>

    <!-- HERO -->
    <section class="hero" id="top">
      <div class="container">
        <div class="hero-eyebrow">The Exit Agency</div>
        <h1 class="hero-headline">
          You get paid to work<br />your business.<br />
          <em>Are you ready to get<br />paid not to?</em>
        </h1>
        <p class="hero-sub">
          We optimize your message and your operations to maximize your value for exit, so you can get more for your business sooner.
        </p>
        <div class="hero-actions">
          <a href="#programs" class="btn-primary">See Our Programs →</a>
          <a href="mailto:hello@conversiv.com" class="btn-ghost">Book a Conversation</a>
        </div>
        <!-- Client logos -->
        <div class="logos-strip">
          <div class="logos-label">Trusted by leaders at</div>
          <div class="logos-row">
            <span class="logo-item">Microsoft</span>
            <span class="logo-item">Cisco</span>
            <span class="logo-item">Yum! Brands</span>
            <span class="logo-item">LifeLock</span>
            <span class="logo-item">Samuel Adams</span>
            <span class="logo-item">Avnet</span>
            <span class="logo-item">Sylvan</span>
          </div>
        </div>
      </div>
    </section>

    <!-- POSITIONING -->
    <section class="positioning" id="about">
      <div class="container">
        <div class="pos-inner">
          <div class="pos-left">
            <h2>Positioning your business<br /><em>for maximum value.</em></h2>
            <p>
