---
const title = "Conversiv — The Exit Agency";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Conversiv — The Exit Agency</title>
    <meta name="description" content="Get more for your business sooner. Conversiv helps owner-operators position their business for a max selling price — by connecting their message to their audiences and their operations." />
    <link rel="icon" type="image/svg+xml" href="/conversiv-mark.svg" />
    <link rel="apple-touch-icon" href="/conversiv-mark.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet" />
    <style is:inline>
      /* ── Reset & Root ──────────────────────────────────────────────── */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root {
        /* Conversiv brand palette (matches live conversiv.com trade dress) */
        --cream:   #F7F6F2;
        --cream2:  #EFEDE6;
        --cream3:  #DCD9CF;
        --ink:     #1A2D45;       /* Conversiv navy */
        --ink2:    #223655;       /* Conversiv navy 2 */
        --amber:   #F18A00;       /* Conversiv orange (var name kept to avoid mass renames) */
        --amber2:  #FF9E1B;       /* Conversiv orange bright */
        --blue:    #4381C3;       /* Conversiv accent blue */
        --gray:    #5A6478;
        --gray2:   #8893A8;
        --muted:   #C4CAD4;
        --navy:    #1A2D45;
        --navy2:   #142236;
        --serif:   'Playfair Display', Georgia, serif;
        --sans:    'Roboto', -apple-system, sans-serif;
      }
      html { scroll-behavior: smooth; }
      body { font-family: var(--sans); background: var(--cream); color: var(--ink); line-height: 1.6; -webkit-font-smoothing: antialiased; font-weight: 400; }
      h1, h2, h3 { font-family: var(--serif); line-height: 1.1; font-weight: 700; color: var(--ink); }
      a { color: inherit; text-decoration: none; }
      .container { max-width: 1180px; margin: 0 auto; padding: 0 2rem; }

      /* ── TOP BAR ─────────────────────────────────────────────────────── */
      .top-bar { background: var(--amber); color: #fff; text-align: center; padding: 0.55rem 1rem; font-size: 0.78rem; font-weight: 500; letter-spacing: 0.03em; }
      .top-bar a { color: #fff; font-weight: 700; text-decoration: underline; text-underline-offset: 2px; }

      /* ── NAV ─────────────────────────────────────────────────────────── */
      nav { position: sticky; top: 0; z-index: 100; background: rgba(247,246,242,0.94); backdrop-filter: blur(12px); border-bottom: 1px solid var(--cream3); padding: 1.25rem 0; }
      .nav-inner { display: flex; align-items: center; justify-content: space-between; gap: 2rem; }
      .nav-logo { display: inline-flex; align-items: baseline; gap: 0.4rem; font-family: var(--serif); font-size: 1.55rem; font-weight: 700; color: var(--ink); letter-spacing: -0.01em; }
      .nav-logo::after { content: ''; display: inline-block; width: 6px; height: 6px; background: var(--amber); border-radius: 50%; transform: translateY(-2px); }
      .nav-links { display: flex; gap: 2.5rem; list-style: none; font-size: 0.78rem; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; color: var(--gray); }
      .nav-links a:hover { color: var(--amber); transition: color 0.2s; }
      .nav-cta { font-size: 0.78rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: #fff; background: var(--ink); padding: 0.65rem 1.5rem; border-radius: 2px; transition: background 0.2s, transform 0.15s; white-space: nowrap; }
      .nav-cta:hover { background: var(--amber); transform: translateY(-1px); }

      /* ── HERO ─────────────────────────────────────────────────────────── */
      .hero { background: var(--cream); padding: 7rem 0 6rem; text-align: center; border-bottom: 1px solid var(--cream3); }
      .hero-chip { display: inline-flex; align-items: center; gap: 0.6rem; background: rgba(241,138,0,0.08); border: 1px solid rgba(241,138,0,0.25); color: var(--amber); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; padding: 0.4rem 1rem; border-radius: 100px; margin-bottom: 2.5rem; }
      .hero-chip::before { content: ''; width: 6px; height: 6px; background: var(--amber); border-radius: 50%; }
      h1.hero-headline {
        font-size: clamp(3.4rem, 8vw, 7.4rem);
        line-height: 1;
        letter-spacing: -0.02em;
        color: var(--ink);
        max-width: 980px;
        margin: 0 auto 2rem;
        font-family: var(--serif);
        font-weight: 700;
      }
      .hero-emph { color: var(--amber); font-style: italic; }
      .hero-sub { font-size: 1.15rem; font-weight: 300; color: var(--gray); max-width: 640px; margin: 0 auto 3rem; line-height: 1.7; }
      .hero-actions { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; margin-bottom: 1.25rem; }
      .btn-ink { display: inline-flex; align-items: center; gap: 0.5rem; background: var(--ink); color: #fff; padding: 1rem 2rem; border-radius: 2px; font-size: 0.875rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; transition: background 0.2s, transform 0.15s; }
      .btn-ink:hover { background: var(--amber); transform: translateY(-2px); }
      .btn-outline { display: inline-flex; align-items: center; gap: 0.5rem; border: 1.5px solid var(--ink); color: var(--ink); padding: 1rem 2rem; border-radius: 2px; font-size: 0.875rem; font-weight: 500; letter-spacing: 0.04em; transition: border-color 0.2s, background 0.2s, color 0.2s; }
      .btn-outline:hover { border-color: var(--amber); color: var(--amber); }
      .magic-link-hint { display: block; font-size: 0.72rem; color: var(--gray2); letter-spacing: 0.02em; margin-top: 0.5rem; margin-bottom: 3rem; font-weight: 400; }
      .magic-link-hint strong { color: var(--ink2); font-weight: 600; }
      .hero-proof { display: flex; align-items: center; justify-content: center; gap: 0.75rem; flex-wrap: wrap; }
      .hero-proof-label { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gray2); }
      .hero-proof-names { display: flex; gap: 0; }
      .proof-name { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--gray); padding: 0 1rem; border-right: 1px solid var(--cream3); }
      .proof-name:last-child { border-right: none; }

      /* ── PROOF MARQUEE ───────────────────────────────────────────────── */
      .proof-marquee { background: var(--ink); overflow: hidden; padding: 1.15rem 0; }
      .proof-track { display: flex; align-items: center; width: max-content; animation: marquee-proof 28s linear infinite; }
      .proof-item { padding: 0 2rem; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(247,246,242,0.55); white-space: nowrap; }
      .proof-dot { color: rgba(241,138,0,0.7); padding: 0 0.5rem; }
      @keyframes marquee-proof { from { transform: translateX(0); } to { transform: translateX(-50%); } }

      /* ── SECTION 2 — Get more for your business sooner ─────────────── */
      .pillar { background: var(--cream); padding: 8rem 0; border-bottom: 1px solid var(--cream3); text-align: center; }
      .pillar-inner { max-width: 760px; margin: 0 auto; }
      .pillar-eyebrow { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: var(--amber); margin-bottom: 1.25rem; display: block; }
      .pillar h2 { font-size: clamp(2.2rem, 4vw, 3.6rem); margin-bottom: 1.75rem; }
      .pillar h2 em { font-style: italic; color: var(--amber); }
      .pillar p { font-size: 1.1rem; color: var(--gray); line-height: 1.7; font-weight: 300; }
      .pillar-cta { margin-top: 2.5rem; }

      /* ── AUTHORITY QUOTE ─────────────────────────────────────────────── */
      .authority-quote { background: var(--cream2); padding: 6rem 0; border-bottom: 1px solid var(--cream3); }
      .aq-inner { max-width: 760px; margin: 0 auto; text-align: center; }
      .aq-eyebrow { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: var(--amber); margin-bottom: 1.75rem; display: inline-flex; align-items: center; gap: 0.6rem; }
      .aq-eyebrow::before, .aq-eyebrow::after { content: ''; width: 24px; height: 1px; background: var(--amber); }
      .aq-text { font-family: var(--serif); font-size: clamp(1.6rem, 3vw, 2.4rem); line-height: 1.3; color: var(--ink); font-style: italic; margin-bottom: 1.75rem; font-weight: 400; }
      .aq-attr { display: inline-flex; flex-direction: column; align-items: center; gap: 0.25rem; padding-top: 1.5rem; border-top: 1px solid var(--cream3); }
      .aq-name { font-size: 0.78rem; font-weight: 600; color: var(--ink); letter-spacing: 0.04em; }
      .aq-role { font-size: 0.72rem; color: var(--gray); font-weight: 300; }

      /* ── EDITORIAL IMAGE BREAK ──────────────────────────────────────── */
      .editorial-break { position: relative; overflow: hidden; background: var(--ink); border-bottom: 1px solid var(--cream3); }
      .editorial-break img { width: 100%; height: 62vh; min-height: 460px; max-height: 720px; object-fit: cover; display: block; filter: grayscale(0.55) brightness(0.55) contrast(1.05); }
      .editorial-overlay { position: absolute; inset: 0; display: flex; flex-direction: column; justify-content: flex-end; pointer-events: none; }
      .editorial-overlay-inner { max-width: 1180px; margin: 0 auto; padding: 0 2rem 4.5rem; width: 100%; pointer-events: auto; }
      .editorial-eyebrow { color: var(--amber2); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; margin-bottom: 1.25rem; display: inline-flex; align-items: center; gap: 0.6rem; }
      .editorial-eyebrow::before { content: ''; width: 28px; height: 1px; background: var(--amber2); }
      .editorial-quote { font-family: var(--serif); font-size: clamp(1.7rem, 3.4vw, 2.8rem); line-height: 1.18; color: #fff; max-width: 780px; font-weight: 400; letter-spacing: -0.01em; }
      .editorial-quote em { font-style: italic; color: var(--amber2); }
      .editorial-attr { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(247,246,242,0.6); margin-top: 1.75rem; }

      /* ── PROGRAMS ─────────────────────────────────────────────────────── */
      .programs { background: var(--cream2); padding: 8rem 0; border-top: 1px solid var(--cream3); border-bottom: 1px solid var(--cream3); }
      .section-eyebrow { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: var(--amber); margin-bottom: 0.75rem; display: block; }
      .section-heading { font-size: clamp(1.9rem, 3.2vw, 2.8rem); color: var(--ink); margin-bottom: 3.5rem; max-width: 640px; }
      .section-heading em { font-style: italic; color: var(--amber); }
      .programs-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5px; background: var(--cream3); border: 1px solid var(--cream3); }
      .prog-card { background: var(--cream2); padding: 3.5rem; transition: background 0.25s; display: flex; flex-direction: column; }
      .prog-card:hover { background: #fff; }
      .prog-num { font-family: var(--serif); font-size: 3rem; color: var(--amber); line-height: 1; margin-bottom: 1rem; opacity: 0.5; font-weight: 700; }
      .prog-card h3 { font-size: 2.2rem; color: var(--ink); margin-bottom: 0.35rem; font-weight: 700; }
      .prog-sub { font-size: 0.82rem; color: var(--amber); font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 1.25rem; }
      .prog-card p { font-size: 0.95rem; color: var(--gray); line-height: 1.85; font-weight: 300; margin-bottom: 1.75rem; }
      .prog-features { list-style: none; display: flex; flex-direction: column; gap: 0; padding-top: 0.5rem; }
      .prog-features li { display: flex; align-items: flex-start; gap: 0.65rem; padding: 0.6rem 0; font-size: 0.9rem; color: var(--ink2); border-bottom: 1px solid rgba(26,45,69,0.06); }
      .prog-features li::before { content: '\2192'; color: var(--amber); flex-shrink: 0; margin-top: 0.15rem; font-weight: 600; }
      .prog-cta { display: inline-flex; align-items: center; gap: 0.4rem; margin-top: 2rem; font-size: 0.78rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink); border-bottom: 1.5px solid var(--ink); padding-bottom: 2px; align-self: flex-start; transition: color 0.2s, border-color 0.2s; }
      .prog-cta:hover { color: var(--amber); border-color: var(--amber); }

      /* ── AGENT EXIT (formerly OPTIQOS — reframed as agency capability, not financial product) */
      .optiqos { background: var(--cream); padding: 8rem 0; border-bottom: 1px solid var(--cream3); }
      .optiqos-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: start; }
      .optiqos-chip { display: inline-flex; align-items: center; gap: 0.5rem; background: rgba(241,138,0,0.08); border: 1px solid rgba(241,138,0,0.25); color: var(--amber); font-size: 0.68rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; padding: 0.35rem 0.9rem; border-radius: 2px; margin-bottom: 1.5rem; }
      .optiqos h2 { font-size: clamp(1.9rem, 3vw, 2.8rem); color: var(--ink); margin-bottom: 0.5rem; }
      .optiqos h2 em { font-style: italic; color: var(--amber); }
      .optiqos-sub { font-size: 0.92rem; color: var(--amber); font-weight: 600; letter-spacing: 0.04em; margin-bottom: 1.25rem; }
      .optiqos p { font-size: 0.95rem; color: var(--gray); line-height: 1.85; font-weight: 300; margin-bottom: 1.1rem; }
      .feature-list { list-style: none; margin-top: 2rem; display: flex; flex-direction: column; gap: 0; border-top: 1.5px solid var(--cream3); padding-top: 1.25rem; }
      .feature-list li { display: flex; align-items: flex-start; gap: 1rem; padding: 1rem 0; border-bottom: 1px solid var(--cream3); font-size: 0.9rem; }
      .feature-list li:last-child { border-bottom: none; }
      .feat-num { font-family: var(--serif); font-size: 1.1rem; color: var(--amber); width: 1.5rem; flex-shrink: 0; margin-top: 0.05rem; font-weight: 700; }
      .feat-text strong { display: block; font-size: 0.88rem; font-weight: 700; color: var(--ink); margin-bottom: 0.2rem; letter-spacing: 0.01em; }
      .feat-text span { font-size: 0.85rem; color: var(--gray); font-weight: 300; line-height: 1.55; }
      .optiqos-visual { position: sticky; top: 6rem; }
      .stat-display { background: var(--cream2); border: 1px solid var(--cream3); border-radius: 4px; padding: 2.5rem; }
      .stat-display-head { font-size: 0.65rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: var(--gray); margin-bottom: 1.5rem; }
      .stat-display-items { display: flex; flex-direction: column; gap: 1rem; }
      .sdi { display: flex; align-items: center; justify-content: space-between; padding: 1rem 1.25rem; background: #fff; border: 1px solid var(--cream3); border-radius: 2px; }
      .sdi-label { font-size: 0.8rem; font-weight: 500; color: var(--ink2); }
      .sdi-value { font-family: var(--serif); font-size: 1.4rem; color: var(--amber); font-weight: 700; }
      .sdi-delta { font-size: 0.65rem; font-weight: 700; color: #15803D; background: rgba(34,197,94,0.1); padding: 0.18rem 0.55rem; border-radius: 100px; letter-spacing: 0.04em; }
      .sdi-delta.warn { color: var(--amber); background: rgba(241,138,0,0.1); }
      .sdi-right { display: flex; align-items: center; gap: 0.5rem; }
      .insight-light { margin-top: 1.25rem; background: rgba(241,138,0,0.08); border: 1px solid rgba(241,138,0,0.22); border-radius: 3px; padding: 0.95rem 1.15rem; font-size: 0.8rem; color: var(--ink2); line-height: 1.6; }
      .insight-light strong { color: var(--amber); }

      /* ── QUOTES ───────────────────────────────────────────────────────── */
      .quotes { background: var(--cream2); padding: 7rem 0; border-top: 1px solid var(--cream3); border-bottom: 1px solid var(--cream3); }
      .quotes-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5px; background: var(--cream3); border: 1px solid var(--cream3); }
      .quote-card { background: var(--cream2); padding: 3rem 2.5rem; }
      .q-mark { font-family: var(--serif); font-size: 4rem; line-height: 0.6; color: var(--amber); opacity: 0.4; margin-bottom: 1.25rem; font-weight: 700; }
      .q-text { font-family: var(--serif); font-style: italic; font-size: 1rem; color: var(--ink2); line-height: 1.7; margin-bottom: 1.5rem; font-weight: 400; }
      .q-outcome { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--amber); display: flex; align-items: center; gap: 0.4rem; margin-bottom: 1.25rem; }
      .q-outcome::before { content: '\2192'; }
      .q-attr { display: flex; align-items: center; gap: 0.85rem; border-top: 1px solid var(--cream3); padding-top: 1rem; }
      .q-headshot { width: 42px; height: 42px; border-radius: 50%; object-fit: cover; flex-shrink: 0; filter: grayscale(0.45); border: 1px solid var(--cream3); background: var(--cream3); }
      .q-meta { flex: 1; min-width: 0; }
      .q-name { font-size: 0.82rem; font-weight: 600; color: var(--ink); }
      .q-role { font-size: 0.72rem; color: var(--gray); font-weight: 300; margin-top: 0.1rem; }

      /* ── PROCESS ─────────────────────────────────────────────────────── */
      .process { background: var(--cream); padding: 8rem 0; border-bottom: 1px solid var(--cream3); }
      .steps-light { display: grid; grid-template-columns: repeat(3, 1fr); gap: 4rem; }
      .step-l { position: relative; }
      .step-l-num { font-family: var(--serif); font-size: 3rem; color: var(--amber); opacity: 0.25; line-height: 1; margin-bottom: 0.75rem; font-weight: 700; }
      .step-l h3 { font-size: 1.15rem; color: var(--ink); margin-bottom: 0.7rem; font-family: var(--sans); font-weight: 700; letter-spacing: -0.01em; }
      .step-l p { font-size: 0.9rem; color: var(--gray); line-height: 1.8; font-weight: 300; }

      /* ── WHY CONNECT WITH CONVERSIV (stat band — Joe's section 3) ── */
      .why-now { background: var(--cream2); padding: 8rem 0; border-bottom: 1px solid var(--cream3); }
      .wn-header { text-align: center; margin-bottom: 5rem; }
      .wn-eyebrow { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: var(--amber); margin-bottom: 1rem; display: block; }
      .wn-heading { font-size: clamp(2.2rem, 4vw, 3.4rem); color: var(--ink); }
      .wn-heading em { font-style: italic; color: var(--amber); }
      .wn-stats { display: grid; grid-template-columns: repeat(2, 1fr); gap: 4rem; max-width: 880px; margin: 0 auto; }
      .wn-stat { text-align: center; padding: 0 1rem; position: relative; }
      .wn-stat:not(:last-child)::after { content: ''; position: absolute; right: -1.5rem; top: 1rem; bottom: 1rem; width: 1px; background: var(--cream3); }
      .wn-stat-num { font-family: var(--serif); font-size: clamp(3.5rem, 6vw, 5.5rem); color: var(--amber); line-height: 0.95; margin-bottom: 1.25rem; font-weight: 700; }
      .wn-stat-label { font-size: 1rem; color: var(--ink2); line-height: 1.55; max-width: 280px; margin: 0 auto; font-weight: 300; }
      .wn-source { text-align: center; margin-top: 4rem; font-size: 0.72rem; color: var(--gray2); letter-spacing: 0.04em; }

      /* ── CTA (DARK INVERSION) ─────────────────────────────────────────── */
      .cta-dark { background: var(--navy2); padding: 8rem 0; text-align: center; }
      .cta-dark h2 { font-size: clamp(2.5rem, 5vw, 4.2rem); color: #fff; max-width: 700px; margin: 0 auto 1.5rem; line-height: 1.05; font-weight: 700; }
      .cta-dark h2 em { font-style: italic; color: var(--amber2); }
      .cta-dark p { font-size: 1rem; color: rgba(247,246,242,0.65); max-width: 480px; margin: 0 auto 2.5rem; font-weight: 300; line-height: 1.75; }
      .cta-dark-actions { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; }
      .btn-amber { display: inline-flex; align-items: center; gap: 0.5rem; background: var(--amber); color: #fff; padding: 1rem 2rem; border-radius: 2px; font-size: 0.875rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; transition: background 0.2s, transform 0.15s; }
      .btn-amber:hover { background: var(--amber2); transform: translateY(-2px); }
      .btn-ghost-light { display: inline-flex; align-items: center; gap: 0.5rem; border: 1px solid rgba(247,246,242,0.3); color: rgba(247,246,242,0.8); padding: 1rem 2rem; border-radius: 2px; font-size: 0.875rem; font-weight: 500; transition: border-color 0.2s, color 0.2s; }
      .btn-ghost-light:hover { border-color: var(--amber2); color: #fff; }
      .cta-note { margin-top: 1.75rem; font-size: 0.75rem; color: rgba(247,246,242,0.45); letter-spacing: 0.07em; }

      /* ── FOOTER ──────────────────────────────────────────────────────── */
      footer { background: var(--ink); padding: 4rem 0 3rem; color: rgba(247,246,242,0.7); }
      .footer-inner { display: grid; grid-template-columns: 1.6fr 1fr 1fr 1.2fr; gap: 3rem; margin-bottom: 3rem; }
      .footer-brand-logo { font-family: var(--serif); font-size: 1.55rem; font-weight: 700; color: #fff; letter-spacing: -0.01em; }
      .footer-brand-logo::after { content: ''; display: inline-block; width: 6px; height: 6px; background: var(--amber); border-radius: 50%; margin-left: 0.4rem; transform: translateY(-4px); }
      .footer-brand-tag { font-size: 0.68rem; color: var(--amber2); letter-spacing: 0.18em; text-transform: uppercase; margin-top: 0.5rem; font-weight: 600; }
      .footer-brand-desc { font-size: 0.85rem; color: rgba(247,246,242,0.6); line-height: 1.7; font-weight: 300; margin-top: 0.85rem; max-width: 260px; }
      .footer-col-head { font-size: 0.65rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--amber2); margin-bottom: 1.1rem; }
      .footer-links-list { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; }
